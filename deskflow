# Begin generated content from clients/shell/commands/doctor.sh
patreage__cmd_doctor() {
	local status="ok"
	local jq_version=""
	local curl_version=""

	if ! command -v jq >/dev/null 2>&1; then
		patreage__die "missing required command: jq"
	fi

	jq_version="$(jq --version)"
	if ! curl_version="$(patreage__detect_command curl)"; then
		status="error"
		curl_version=""
	fi

	jq -n \
		--arg status "${status}" \
		--arg bash_version "$(patreage__bash_version)" \
		--arg jq_version "${jq_version}" \
		--arg curl_version "${curl_version}" \
		--arg api_base_url "$(patreage__api_public_base_url)" \
		--arg repo_root "$(patreage__repo_root)" \
		--arg state_file "$(patreage__state_file)" \
		'{
      status: $status,
      bash: {
        required: ">=5",
        detected: $bash_version
      },
      jq: {
        required: true,
        detected: $jq_version
      },
      curl: {
        required: true,
        detected: (if $curl_version == "" then null else $curl_version end)
      },
      api_base_url: $api_base_url,
      repo_root: $repo_root,
      state: {
        file: $state_file
      }
    }'

	if [[ "${status}" != "ok" ]]; then
		exit 1
	fi
}
