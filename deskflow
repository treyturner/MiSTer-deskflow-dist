patreage__doctor_validate_repo_selector() {
	local selector="$1"
	local owner
	local repo

	if [[ -z "${selector}" || "${selector}" == -* || "${selector}" != */* || "${selector}" == */*/* ]]; then
		return 1
	fi
	owner="${selector%%/*}"
	repo="${selector#*/}"
	if [[ -z "${owner}" || -z "${repo}" ]]; then
		return 1
	fi
	if [[ "${owner}" == "." || "${owner}" == ".." || "${repo}" == "." || "${repo}" == ".." ]]; then
		return 1
	fi
	[[ "${owner}" =~ ^[A-Za-z0-9_.-]+$ && "${repo}" =~ ^[A-Za-z0-9_.-]+$ ]]
}

patreage__doctor_requirement_json() {
	local curl_status="ok"
	local curl_version=""
	local bash_status="ok"
	local filter

	if ((BASH_VERSINFO[0] < 5)); then
		bash_status="failed"
	fi
	if ! curl_version="$(patreage__detect_command curl)"; then
		curl_status="missing"
		curl_version=""
	fi

	filter='{bash:{status:$bash_status,required:">=5",detected:$bash_version},jq:{status:"ok",required:true,detected:$jq_version},curl:{status:$curl_status,required:true,detected:(if $curl_version == "" then null else $curl_version end)}}'
	jq -n \
		--arg bash_status "${bash_status}" \
		--arg bash_version "$(patreage__bash_version)" \
		--arg jq_version "$(jq --version)" \
		--arg curl_status "${curl_status}" \
		--arg curl_version "${curl_version}" \
		"${filter}"
}

patreage__doctor_http_status_json() {
	local http_status="$1"

	if [[ "${http_status}" =~ ^[0-9]+$ && "${http_status}" != "000" ]]; then
		printf '%s\n' "${http_status}"
		return 0
	fi

	printf 'null\n'
}

patreage__doctor_response_body_json() {
	local response_body="$1"

	if [[ -n "${response_body}" ]] && printf '%s\n' "${response_body}" | jq empty >/dev/null 2>&1; then
		printf '%s\n' "${response_body}"
		return 0
	fi

	printf 'null\n'
}

patreage__doctor_healthz_json() {
	local base_url="$1"
	local curl_status="$2"
	local api_url_valid="$3"
	local http_status_json
	local response_body_json
	local error_code=""
	local detail=""
	local check_status="ok"
	local filter

	if [[ "${curl_status}" != "ok" ]]; then
		filter='{status:"skipped",http_status:null,error_code:"curl_missing",detail:"curl is required for the /healthz probe",body:null}'
		jq -n "${filter}"
		return 0
	fi

	if [[ "${api_url_valid}" != "true" ]]; then
		filter='{status:"failed",http_status:null,error_code:"api_base_url_invalid",detail:"effective API base URL is invalid",body:null}'
		jq -n "${filter}"
		return 0
	fi

	if ! patreage__api_request_json "GET" "/healthz" "" "" "${base_url}" 2>/dev/null; then
		http_status_json="$(patreage__doctor_http_status_json "${PATREAGE__HTTP_RESPONSE_STATUS}")"
		filter='{status:"unavailable",http_status:$http_status,error_code:"api_unreachable",detail:$detail,body:null}'
		jq -n \
			--argjson http_status "${http_status_json}" \
			--arg detail "failed to contact API at ${base_url}" \
			"${filter}"
		return 0
	fi

	http_status_json="$(patreage__doctor_http_status_json "${PATREAGE__HTTP_RESPONSE_STATUS}")"
	response_body_json="$(patreage__doctor_response_body_json "${PATREAGE__HTTP_RESPONSE_BODY}")"
	if [[ "${PATREAGE__HTTP_RESPONSE_STATUS}" != "200" ]]; then
		check_status="failed"
		error_code="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.error // "healthz_failed"' 2>/dev/null || printf 'healthz_failed\n')"
		detail="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.detail // empty' 2>/dev/null || printf '\n')"
		if [[ -z "${detail}" ]]; then
			detail="healthz returned HTTP ${PATREAGE__HTTP_RESPONSE_STATUS}"
		fi
	fi

	filter='{status:$status,http_status:$http_status,error_code:(if $error_code == "" then null else $error_code end),detail:(if $detail == "" then null else $detail end),body:$body}'
	jq -n \
		--arg status "${check_status}" \
		--arg error_code "${error_code}" \
		--arg detail "${detail}" \
		--argjson http_status "${http_status_json}" \
		--argjson body "${response_body_json}" \
		"${filter}"
}

patreage__doctor_dns_json() {
	local host="$1"
	local dns_output=""
	local address=""
	local tool=""
	local tried_tool="false"
	local status="failed"
	local detail=""
	local filter

	if [[ -z "${host}" ]]; then
		filter='{status:"skipped",tool:null,host:null,address:null,detail:"effective API host is unavailable"}'
		jq -n "${filter}"
		return 0
	fi

	if command -v getent >/dev/null 2>&1; then
		tried_tool="true"
		tool="getent"
		if dns_output="$(getent hosts "${host}" 2>/dev/null)" && [[ -n "${dns_output}" ]]; then
			read -r address _ <<<"${dns_output}"
			status="ok"
		else
			detail="DNS lookup failed with getent"
		fi
	fi
	if [[ "${status}" != "ok" ]] && command -v nslookup >/dev/null 2>&1; then
		tried_tool="true"
		tool="nslookup"
		if nslookup "${host}" >/dev/null 2>&1; then
			status="ok"
			detail=""
		else
			detail="DNS lookup failed with nslookup"
		fi
	fi
	if [[ "${status}" != "ok" ]] && command -v host >/dev/null 2>&1; then
		tried_tool="true"
		tool="host"
		if host "${host}" >/dev/null 2>&1; then
			status="ok"
			detail=""
		else
			detail="DNS lookup failed with host"
		fi
	fi
	if [[ "${tried_tool}" == "false" ]]; then
		status="unavailable"
		detail="getent, nslookup, and host are unavailable"
	fi

	filter='{status:$status,tool:(if $tool == "" then null else $tool end),host:$host,address:(if $address == "" then null else $address end),detail:(if $detail == "" then null else $detail end)}'
	jq -n \
		--arg status "${status}" \
		--arg tool "${tool}" \
		--arg host "${host}" \
		--arg address "${address}" \
		--arg detail "${detail}" \
		"${filter}"
}

patreage__doctor_icmp_json() {
	local host="$1"
	local status="ok"
	local detail=""
	local filter

	if [[ -z "${host}" ]]; then
		filter='{status:"skipped",tool:null,host:null,detail:"effective API host is unavailable"}'
		jq -n "${filter}"
		return 0
	fi

	if ! command -v ping >/dev/null 2>&1; then
		filter='{status:"unavailable",tool:null,host:$host,detail:"ping is unavailable"}'
		jq -n \
			--arg host "${host}" \
			"${filter}"
		return 0
	fi

	if ! ping -c 1 -W 1 "${host}" >/dev/null 2>&1; then
		status="failed"
		detail="ping failed or was blocked"
	fi

	filter='{status:$status,tool:"ping",host:$host,detail:(if $detail == "" then null else $detail end)}'
	jq -n \
		--arg status "${status}" \
		--arg host "${host}" \
		--arg detail "${detail}" \
		"${filter}"
}

patreage__doctor_state_json() {
	local status_json="$1"
