patreage__doctor_map_repo_status() {
	local http_status="$1"
	local error_code="$2"

	case "${http_status}" in
	200)
		printf 'granted\n'
		;;
	401)
		printf 'unauthenticated\n'
		;;
	403)
		printf 'denied\n'
		;;
	404)
		if [[ "${error_code}" == "repo_access_repo_not_configured" ]]; then
			printf 'not_configured\n'
		else
			printf 'error\n'
		fi
		;;
	503)
		printf 'unavailable\n'
		;;
	"")
		printf 'unavailable\n'
		;;
	*)
		printf 'error\n'
		;;
	esac
}

patreage__doctor_append_repo_result() {
	local repos_json="$1"
	local repo_json="$2"

	jq -c \
		--argjson repo "${repo_json}" \
		'. + [$repo]' <<<"${repos_json}"
}

patreage__doctor_collect_repos_json() {
	local curl_status="$1"
	local session_json="$2"
	shift 2
	local -a repo_selectors=("$@")
	local repos_json="[]"
	local selector=""
	local selector_json
	local target
	local repo_json
	local session_status
	local session_reason
	local http_status_json
	local repo_status
	local result_json

	session_status="$(printf '%s\n' "${session_json}" | jq -r '.status')"
	session_reason="$(printf '%s\n' "${session_json}" | jq -r '.reason // empty')"

	if ((${#repo_selectors[@]} == 0)); then
		repo_selectors=("")
	fi

	for selector in "${repo_selectors[@]}"; do
		if [[ -z "${selector}" ]]; then
			selector_json="null"
			target="default"
		else
			selector_json="$(jq -n --arg selector "${selector}" '$selector')"
			target="${selector}"
		fi

		if [[ "${curl_status}" != "ok" ]]; then
			repo_json="$(
				patreage__doctor_skipped_repo_result_json \
					"${selector_json}" \
					"${target}" \
					"unavailable" \
					"curl_missing" \
					"curl is required for repo access checks"
			)"
			repos_json="$(patreage__doctor_append_repo_result "${repos_json}" "${repo_json}")"
			continue
		fi

		if [[ "${session_status}" != "authenticated" ]]; then
			repo_json="$(
				patreage__doctor_skipped_repo_result_json \
					"${selector_json}" \
					"${target}" \
					"unauthenticated" \
					"${session_reason:-not_authenticated}" \
					"patreage login is required before repo checks can run"
			)"
			repos_json="$(patreage__doctor_append_repo_result "${repos_json}" "${repo_json}")"
			continue
		fi

		if patreage__repo_access_check_request "${selector}"; then
			:
		fi
		http_status_json="$(patreage__repo_access_check_http_status_json "${PATREAGE__REPO_ACCESS_CHECK_HTTP_STATUS}")"
		repo_status="$(
			patreage__doctor_map_repo_status \
				"${PATREAGE__REPO_ACCESS_CHECK_HTTP_STATUS}" \
				"${PATREAGE__REPO_ACCESS_CHECK_ERROR_CODE}"
		)"
		result_json="$(patreage__doctor_response_body_json "${PATREAGE__REPO_ACCESS_CHECK_RESPONSE_JSON}")"
		repo_json="$(
			patreage__doctor_repo_result_json \
				"${selector_json}" \
				"${target}" \
				"${repo_status}" \
				"${http_status_json}" \
				"${PATREAGE__REPO_ACCESS_CHECK_ERROR_CODE}" \
				"${PATREAGE__REPO_ACCESS_CHECK_DETAIL}" \
				"${result_json}" \
				"${PATREAGE__REPO_ACCESS_CHECK_REFRESH_OUTCOME}"
		)"
		repos_json="$(patreage__doctor_append_repo_result "${repos_json}" "${repo_json}")"
	done

	printf '%s\n' "${repos_json}"
}

patreage__doctor_final_json() {
	local requirements_json="$1"
	local api_json="$2"
	local connectivity_json="$3"
	local state_json="$4"
	local session_json="$5"
	local repo_check_scope="$6"
	local repos_json="$7"
	local filter

	filter='def requirement_problem: ($requirements | to_entries | any(.value.status == "missing" or .value.status == "failed"));'
	filter+=' def api_problem: ($api.healthz.status == "failed" or $api.healthz.status == "unavailable");'
	filter+=' def action_session: ($session.status == "unauthenticated" or $session.status == "invalid" or $session.status == "expired");'
	filter+=' def action_repo: ($repos_checked | any(.status == "denied" or .status == "not_configured" or .status == "unauthenticated"));'
	filter+=' def error_repo: ($repos_checked | any(.status == "unavailable" or .status == "error"));'
	filter+=' def degraded_connectivity: ($connectivity.dns.status != "ok" or $connectivity.icmp.status != "ok");'
	filter+=' def degraded_session: ((($session.remote_summary_status // "") | startswith("stale_")) or (($session.remote_summary_status // "") | startswith("unavailable_")) or (($session.remote_summary_status // "") == "unauthorized") or (($session.remote_summary_status // "") == "unlinked_legacy_session"));'
	filter+=' def warning_items: [] + (if $connectivity.dns.status != "ok" then [{code:("dns_" + $connectivity.dns.status),detail:($connectivity.dns.detail // "DNS probe did not succeed")}] else [] end) + (if $connectivity.icmp.status != "ok" then [{code:("icmp_" + $connectivity.icmp.status),detail:($connectivity.icmp.detail // "ICMP probe did not succeed")}] else [] end) + (if degraded_session then [{code:("session_summary_" + ($session.remote_summary_status // "unknown")),detail:($session.remote_summary_error // "remote session summary is not fresh")}] else [] end);'
	filter+=' def error_items: [] + ($requirements | to_entries | map(select(.value.status == "missing" or .value.status == "failed") | {code:(.key + "_" + .value.status),detail:("required command or runtime is not ready: " + .key)})) + (if api_problem then [{code:($api.healthz.error_code // "api_healthz_failed"),detail:($api.healthz.detail // "API health check failed")}] else [] end) + (if action_session then [{code:($session.reason // "session_action_required"),detail:"local broker session is not ready"}] else [] end) + ($repos_checked | map(select(.status != "granted") | {code:(.error_code // ("repo_" + .status)),detail:(.detail // ("repo check " + .target + " is " + .status)),target:.target}));'
	filter+=' (if requirement_problem or action_session or action_repo then "action_required" elif api_problem or error_repo then "error" elif degraded_connectivity or degraded_session then "degraded" else "ok" end) as $status | {schema_version:1,status:$status,generated_at:(now | todateiso8601),client:{name:"patreage-shell",version:$shell_version,bash:{required:">=5",detected:$bash_version}},requirements:$requirements,api:$api,connectivity:$connectivity,state:$state,session:$session,repo_check_scope:$repo_check_scope,repos_checked:$repos_checked,warnings:warning_items,errors:error_items}'
	jq -n \
		--arg shell_version "${PATREAGE__SHELL_VERSION}" \
		--arg bash_version "$(patreage__bash_version)" \
		--arg repo_check_scope "${repo_check_scope}" \
		--argjson requirements "${requirements_json}" \
		--argjson api "${api_json}" \
		--argjson connectivity "${connectivity_json}" \
		--argjson state "${state_json}" \
		--argjson session "${session_json}" \
		--argjson repos_checked "${repos_json}" \
		"${filter}"
}

patreage__cmd_doctor() {
	local -a repo_selectors=()
	local argument
	local requirements_json
	local curl_status
	local status_json
	local state_json
	local session_json
	local configured_api_base_url
	local effective_api_base_url
	local effective_api_base_url_source="config"
	local api_url_valid="false"
	local api_scheme=""
	local api_host=""
	local api_port=""
	local api_origin=""
	local healthz_json
	local dns_json
	local icmp_json
	local api_json
	local connectivity_json
	local repo_check_scope="default"
	local repos_json
	local final_json
	local final_status

	while (($# > 0)); do
		argument="$1"
		case "${argument}" in
		-*)
			patreage__warn "unknown doctor argument: ${argument}"
			exit "${PATREAGE__EXIT_USAGE}"
			;;
		*)
			if ! patreage__doctor_validate_repo_selector "${argument}"; then
				patreage__warn "doctor repo arguments must use OWNER/REPO"
				exit "${PATREAGE__EXIT_USAGE}"
			fi
			repo_selectors+=("${argument}")
			;;
		esac
		shift
	done

	if ! command -v jq >/dev/null 2>&1; then
		patreage__doctor_missing_jq_json
		exit 1
	fi

	requirements_json="$(patreage__doctor_requirement_json)"
	curl_status="$(printf '%s\n' "${requirements_json}" | jq -r '.curl.status')"

	patreage__collect_status 2>/dev/null
	status_json="${PATREAGE__STATUS_JSON}"
	state_json="$(patreage__doctor_state_json "${status_json}")"
	session_json="$(patreage__doctor_session_json "${status_json}")"

	configured_api_base_url="$(patreage__api_public_base_url)"
	effective_api_base_url="$(printf '%s\n' "${session_json}" | jq -r '.api_base_url // empty')"
	if [[ -n "${effective_api_base_url}" ]]; then
		effective_api_base_url_source="session"
	else
		effective_api_base_url="${configured_api_base_url}"
	fi

	if patreage__parse_url "${effective_api_base_url}"; then
		api_url_valid="true"
		api_scheme="${PATREAGE__PARSED_URL_SCHEME}"
		api_host="${PATREAGE__PARSED_URL_HOST}"
		api_port="${PATREAGE__PARSED_URL_PORT}"
		if [[ -z "${api_port}" ]]; then
			api_port="$(patreage__default_port_for_scheme "${api_scheme}")"
		fi
		api_origin="$(patreage__url_origin_from_parts "${api_scheme}" "${api_host}" "${api_port}")"
	fi

	healthz_json="$(patreage__doctor_healthz_json "${effective_api_base_url}" "${curl_status}" "${api_url_valid}")"
	dns_json="$(patreage__doctor_dns_json "${api_host}")"
	icmp_json="$(patreage__doctor_icmp_json "${api_host}")"
	api_json="$(
		jq -n \
			--arg configured_public_base_url "${configured_api_base_url}" \
			--arg effective_base_url "${effective_api_base_url}" \
			--arg effective_base_url_source "${effective_api_base_url_source}" \
			--arg scheme "${api_scheme}" \
			--arg host "${api_host}" \
			--arg port "${api_port}" \
			--arg origin "${api_origin}" \
			--argjson healthz "${healthz_json}" \
			'{
        configured_public_base_url: $configured_public_base_url,
        effective_base_url: $effective_base_url,
        effective_base_url_source: $effective_base_url_source,
        parsed: {
          scheme: (if $scheme == "" then null else $scheme end),
          host: (if $host == "" then null else $host end),
          port: (if $port == "" then null else ($port | tonumber) end),
          origin: (if $origin == "" then null else $origin end)
        },
        healthz: $healthz
      }'
	)"
	connectivity_json="$(
		jq -n \
			--argjson dns "${dns_json}" \
			--argjson icmp "${icmp_json}" \
			'{dns: $dns, icmp: $icmp}'
	)"

	if ((${#repo_selectors[@]} > 0)); then
		repo_check_scope="explicit"
	fi
	repos_json="$(patreage__doctor_collect_repos_json "${curl_status}" "${session_json}" "${repo_selectors[@]}")"
	final_json="$(
		patreage__doctor_final_json \
			"${requirements_json}" \
			"${api_json}" \
			"${connectivity_json}" \
			"${state_json}" \
			"${session_json}" \
			"${repo_check_scope}" \
			"${repos_json}"
	)"
	printf '%s\n' "${final_json}"

	final_status="$(printf '%s\n' "${final_json}" | jq -r '.status')"
	case "${final_status}" in
	ok | degraded)
		exit 0
		;;
	*)
		exit 1
		;;
	esac
}
