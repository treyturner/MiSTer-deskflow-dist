	patreage__require_command curl

	PATREAGE__CREDENTIAL_PROTOCOL=""
	PATREAGE__CREDENTIAL_HOST=""
	PATREAGE__CREDENTIAL_PATH=""

	while IFS= read -r line; do
		[[ -z "${line}" ]] && break
		key="${line%%=*}"
		value="${line#*=}"
		case "${key}" in
		protocol)
			PATREAGE__CREDENTIAL_PROTOCOL="${value}"
			;;
		host)
			PATREAGE__CREDENTIAL_HOST="${value}"
			;;
		path)
			PATREAGE__CREDENTIAL_PATH="${value}"
			;;
		url)
			patreage__credential_helper_parse_url "${value}"
			;;
		esac
	done

	mismatch_code="$(patreage__credential_helper_mismatch_code \
		"${PATREAGE__CREDENTIAL_PROTOCOL}" \
		"${PATREAGE__CREDENTIAL_HOST}")"
	if [[ -n "${mismatch_code}" ]]; then
		exit 0
	fi

	if ! patreage__resolve_repo_session; then
		patreage__credential_helper_print_error "${PATREAGE__SESSION_ERROR_CODE}" "${PATREAGE__SESSION_ERROR_DETAIL}"
		exit 1
	fi

	payload="$(jq -n \
		--arg protocol "${PATREAGE__CREDENTIAL_PROTOCOL}" \
		--arg host "${PATREAGE__CREDENTIAL_HOST}" \
		--arg path "${PATREAGE__CREDENTIAL_PATH#"/"}" \
		'{
      protocol: $protocol,
      host: $host,
      path: $path
    }')"

	if ! patreage__api_request_json "POST" "/v1/repo-access/git-credentials" "${payload}" "${PATREAGE__SESSION_ACCESS_TOKEN}" "${PATREAGE__SESSION_API_BASE_URL}"; then
		patreage__credential_helper_print_error \
			"$(patreage__machine_code credential_helper_codes request_failed)" \
			"failed to contact API at ${PATREAGE__SESSION_API_BASE_URL}"
		exit 1
	fi

	case "${PATREAGE__HTTP_RESPONSE_STATUS}" in
	200)
		printf 'username=%s\n' "$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.username')"
		printf 'password=%s\n' "$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.password')"
		exit 0
		;;
	404)
		error_code="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.error // empty')"
		if [[ "${error_code}" == "repo_access_repo_context_mismatch" ]]; then
			exit 0
		fi
		;;
	esac

	error_code="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.error // empty')"
	error_detail="$(patreage__response_detail)"
	patreage__credential_helper_print_error "${error_code}" "${error_detail}"
	exit 1
}
# End generated content from clients/shell/commands/credential_helper.sh

patreage__main() {
	local command="${1:-help}"
	if (($# > 0)); then
		shift
	fi

	case "${command}" in
	help)
		patreage__cmd_help "$@"
		;;
	version)
		patreage__cmd_version "$@"
		;;
	doctor)
		patreage__cmd_doctor "$@"
		;;
	login)
		patreage__cmd_login "$@"
		;;
	logout)
		patreage__cmd_logout "$@"
		;;
	status)
		patreage__cmd_status "$@"
		;;
	repo-access)
		patreage__cmd_repo_access "$@"
		;;
	credential-helper)
		patreage__cmd_credential_helper "$@"
		;;
	*)
		patreage__unknown_command "${command}"
		;;
	esac
}

patreage_client() (
	set -euo pipefail

	if ((BASH_VERSINFO[0] < 5)); then
		printf 'patreage requires Bash 5 or newer.\n' >&2
		exit 2
	fi

	patreage__initialize_module_state
	patreage__main "$@"
)

patreage_module_version() (
	set -euo pipefail
	patreage__initialize_module_state
	patreage__cmd_version
)

patreage_require_runtime() (
	set -euo pipefail

	if ((BASH_VERSINFO[0] < 5)); then
		printf 'patreage requires Bash 5 or newer.\n' >&2
		exit 2
	fi

	patreage__initialize_module_state
	patreage__require_command jq
	patreage__require_command curl
)

patreage__module_direct_main() {
	printf 'patreage-module.sh is a sourceable Bash module.\n' >&2
	printf 'Use: source %s; patreage_client <command>\n' "${BASH_SOURCE[0]}" >&2
	printf 'For standalone CLI use, run clients/shell/bin/patreage.\n' >&2
	exit 64
}

