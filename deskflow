# Begin generated content from clients/shell/commands/login.sh
patreage__cmd_login() {
	local start_payload
	local auth_session_id
	local user_code
	local verification_url
	local verification_url_complete
	local poll_token
	local interval_seconds
	local poll_payload
	local poll_state
	local exchange_token
	local exchange_payload
	local state_payload
	local device_name
	local exchange_body
	local access_token
	local session_summary_body="null"
	local remote_summary_status="unavailable_initial_fetch_failed"
	local remote_summary_error=""
	local entitlement_state=""
	local creator_access_state=""
	local session_api_base_url

	if (($# > 0)); then
		patreage__warn "login does not accept arguments"
		exit "${PATREAGE__EXIT_USAGE}"
	fi

	patreage__require_command jq
	patreage__require_command curl

	if ! patreage__validate_state_path_permissions; then
		patreage__die "refusing to use a state path with overly broad permissions"
	fi

	device_name="${HOSTNAME:-}"
	if [[ -z "${device_name}" ]] && command -v hostname >/dev/null 2>&1; then
		device_name="$(hostname)"
	fi
	if [[ -z "${device_name}" ]]; then
		device_name="unknown-shell-host"
	fi

	start_payload="$(jq -n \
		--arg client_kind "shell" \
		--arg shell_version "${PATREAGE__SHELL_VERSION}" \
		--arg device_name "${device_name}" \
		'{
      client_kind: $client_kind,
      shell_version: $shell_version,
      device_name: $device_name
    }')"

	if ! patreage__api_request_json "POST" "/v1/auth-sessions" "${start_payload}"; then
		patreage__die "failed to contact API at $(patreage__api_public_base_url)"
	fi
	if [[ "${PATREAGE__HTTP_RESPONSE_STATUS}" != "201" ]]; then
		patreage__die "$(patreage__response_detail)"
	fi

	auth_session_id="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.auth_session_id')"
	user_code="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.user_code')"
	verification_url="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.verification_url')"
	verification_url_complete="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.verification_url_complete')"
	poll_token="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.poll_token')"
	interval_seconds="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.interval_seconds')"

	if ! patreage__validate_same_origin_auth_url "${verification_url}" "$(patreage__api_public_base_url)"; then
		patreage__die "unsafe verification URL was returned by the API"
	fi
	if ! patreage__validate_same_origin_auth_url "${verification_url_complete}" "$(patreage__api_public_base_url)"; then
		patreage__die "unsafe direct verification URL was returned by the API"
	fi
	if ! patreage__validate_printed_api_field "${user_code}"; then
		patreage__die "unsafe short code was returned by the API"
	fi

	patreage__note "Open this URL in a browser: ${verification_url}"
	patreage__note "Short code: ${user_code}"
	patreage__note "Direct verification link: ${verification_url_complete}"
	patreage__note "Waiting for approval..."

	while true; do
		sleep "${interval_seconds}"
		poll_payload="$(jq -n \
			--arg auth_session_id "${auth_session_id}" \
			--arg poll_token "${poll_token}" \
			'{
        auth_session_id: $auth_session_id,
        poll_token: $poll_token
      }')"
		if ! patreage__api_request_json "POST" "/v1/auth-sessions/poll" "${poll_payload}"; then
			patreage__die "failed to poll API at $(patreage__api_public_base_url)"
		fi

		case "${PATREAGE__HTTP_RESPONSE_STATUS}" in
		200)
			poll_state="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.state')"
			if [[ "${poll_state}" == "pending" ]]; then
				continue
			fi
			if [[ "${poll_state}" != "approved" ]]; then
				patreage__die "unexpected auth session state: ${poll_state}"
			fi
			exchange_token="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.exchange_token')"
			break
			;;
		410)
			patreage__die "$(patreage__response_detail)"
			;;
		*)
			patreage__die "$(patreage__response_detail)"
			;;
		esac
	done

	exchange_payload="$(jq -n \
		--arg auth_session_id "${auth_session_id}" \
		--arg exchange_token "${exchange_token}" \
		'{
      auth_session_id: $auth_session_id,
      exchange_token: $exchange_token
    }')"
	if ! patreage__api_request_json "POST" "/v1/auth-sessions/exchange" "${exchange_payload}"; then
		patreage__die "failed to exchange auth session with API"
	fi
	if [[ "${PATREAGE__HTTP_RESPONSE_STATUS}" != "200" ]]; then
		patreage__die "$(patreage__response_detail)"
	fi

	exchange_body="${PATREAGE__HTTP_RESPONSE_BODY}"
	access_token="$(printf '%s\n' "${exchange_body}" | jq -r '.access_token')"
	session_api_base_url="$(patreage__api_public_base_url)"

	if patreage__api_request_json "GET" "/v1/session" "" "${access_token}" "${session_api_base_url}"; then
		if [[ "${PATREAGE__HTTP_RESPONSE_STATUS}" == "200" ]]; then
			session_summary_body="${PATREAGE__HTTP_RESPONSE_BODY}"
			remote_summary_status="fresh"
			remote_summary_error=""
			entitlement_state="$(printf '%s\n' "${session_summary_body}" | jq -r '.entitlement.state')"
			creator_access_state="$(printf '%s\n' "${session_summary_body}" | jq -r '.creator_access.state // empty')"
		else
			remote_summary_error="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.error // "request_failed"')"
		fi
	else
		remote_summary_error="request_failed"
	fi

	state_payload="$(printf '%s\n' "${exchange_body}" | jq \
		--arg api_base_url "${session_api_base_url}" \
		--arg remote_summary_status "${remote_summary_status}" \
		--arg remote_summary_error "${remote_summary_error}" \
		--argjson remote_summary "${session_summary_body}" \
		'{
      schema_version: 2,
      api_base_url: $api_base_url,
      broker_session_id: .broker_session_id,
      access_token: .access_token,
      access_token_expires_at: .access_token_expires_at,
      refresh_token: .refresh_token,
      refresh_token_expires_at: .refresh_token_expires_at,
      token_type: .token_type,
      remote_summary_status: $remote_summary_status,
      remote_summary_error: (if $remote_summary_error == "" then null else $remote_summary_error end),
      remote_summary_fetched_at: (
        if $remote_summary_status == "fresh"
        then (now | todateiso8601)
        else null
        end
      ),
      remote_summary: (
        if $remote_summary_status == "fresh"
        then $remote_summary
        else null
        end
      ),
      written_at: (now | todateiso8601)
    }')"
	if ! patreage__write_state_json "${state_payload}"; then
		patreage__die "failed to persist local session state"
	fi

	patreage__note "Login complete."
	if [[ "${remote_summary_status}" != "fresh" ]]; then
		patreage__warn "authenticated, but failed to fetch the remote session summary"
	elif [[ "${entitlement_state}" == "not_entitled" && "${creator_access_state}" != "active" ]]; then
		patreage__warn "authenticated successfully, but this Patreon account is not entitled for the configured campaign"
	fi
}
# End generated content from clients/shell/commands/login.sh

# Begin generated content from clients/shell/commands/status.sh
patreage__collect_status() {
	local state_json
	local read_exit=0
	local remote_summary_json="null"
	local remote_summary_status=""
	local remote_summary_error=""
	local remote_summary_fetched_at=""
	local access_token=""
	local access_token_expired="false"
	local refresh_token_expired="false"
	local session_api_base_url=""
	local updated_state_json

	PATREAGE__STATUS_JSON=""
	PATREAGE__STATUS_EXIT=0

	if state_json="$(patreage__read_state_json)"; then
		:
	else
		read_exit=$?
		if [[ "${read_exit}" -eq 2 ]]; then
			PATREAGE__STATUS_JSON="$(
				jq -n \
					--arg state_file "$(patreage__state_file)" \
					'{
            authenticated: false,
            reason: "invalid_state_permissions",
            state_file: $state_file
          }'
			)"
			PATREAGE__STATUS_EXIT=1
			return 0
		fi

		PATREAGE__STATUS_JSON="$(
			jq -n \
				--arg state_file "$(patreage__state_file)" \
				'{
          authenticated: false,
          reason: "not_logged_in",
          state_file: $state_file
        }'
		)"
		PATREAGE__STATUS_EXIT=1
		return 0
	fi

	if ! printf '%s\n' "${state_json}" | jq empty >/dev/null 2>&1; then
		PATREAGE__STATUS_JSON="$(
			jq -n \
				--arg state_file "$(patreage__state_file)" \
				'{
          authenticated: false,
          reason: "invalid_state_json",
          state_file: $state_file
        }'
		)"
		PATREAGE__STATUS_EXIT=1
		return 0
	fi

	if ! patreage__state_json_is_valid "${state_json}"; then
		PATREAGE__STATUS_JSON="$(
			jq -n \
				--arg state_file "$(patreage__state_file)" \
				'{
          authenticated: false,
          reason: "invalid_state_json",
          state_file: $state_file
        }'
		)"
		PATREAGE__STATUS_EXIT=1
		return 0
	fi

	remote_summary_json="$(printf '%s\n' "${state_json}" | jq -c '.remote_summary // null')"
	remote_summary_fetched_at="$(printf '%s\n' "${state_json}" | jq -r '.remote_summary_fetched_at // empty')"
	session_api_base_url="$(printf '%s\n' "${state_json}" | jq -r '.api_base_url')"
	access_token="$(printf '%s\n' "${state_json}" | jq -r '.access_token')"

	if patreage__state_timestamp_expired "${state_json}" "access_token_expires_at"; then
		access_token_expired="true"
	fi

	if patreage__state_timestamp_expired "${state_json}" "refresh_token_expires_at"; then
		refresh_token_expired="true"
	fi

	if [[ "${refresh_token_expired}" == "false" && "${access_token_expired}" == "false" ]]; then
		if command -v curl >/dev/null 2>&1; then
			if patreage__api_request_json "GET" "/v1/session" "" "${access_token}" "${session_api_base_url}"; then
				if [[ "${PATREAGE__HTTP_RESPONSE_STATUS}" == "200" ]]; then
					remote_summary_json="${PATREAGE__HTTP_RESPONSE_BODY}"
					remote_summary_status="fresh"
					remote_summary_error=""
					remote_summary_fetched_at="$(jq -nr 'now | todateiso8601')"
					updated_state_json="$(printf '%s\n' "${state_json}" | jq \
						--argjson remote_summary "${remote_summary_json}" \
						--arg fetched_at "${remote_summary_fetched_at}" \
						'
              .schema_version = (if (.schema_version // 1) < 2 then 2 else .schema_version end)
              | .remote_summary_status = "fresh"
              | .remote_summary_error = null
              | .remote_summary_fetched_at = $fetched_at
              | .remote_summary = $remote_summary
              | .written_at = (now | todateiso8601)
            ')"
					if ! patreage__write_state_json "${updated_state_json}"; then
						patreage__warn "failed to refresh cached session summary on disk"
					fi
				elif [[ "${PATREAGE__HTTP_RESPONSE_STATUS}" == "401" ]]; then
					remote_summary_error="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.error // "request_failed"')"
					if [[ "${remote_summary_error}" == "broker_session_user_unlinked" ]]; then
						remote_summary_status="unlinked_legacy_session"
					else
						remote_summary_status="unauthorized"
					fi
				else
					remote_summary_error="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.error // "request_failed"')"
					if [[ "${remote_summary_json}" == "null" ]]; then
						remote_summary_status="unavailable_api_unreachable"
					else
						remote_summary_status="stale_api_unreachable"
					fi
				fi
			else
				remote_summary_error="request_failed"
				if [[ "${remote_summary_json}" == "null" ]]; then
					remote_summary_status="unavailable_api_unreachable"
				else
					remote_summary_status="stale_api_unreachable"
				fi
			fi
		else
			remote_summary_error="curl_unavailable"
			if [[ "${remote_summary_json}" == "null" ]]; then
				remote_summary_status="unavailable_api_unreachable"
			else
				remote_summary_status="stale_api_unreachable"
			fi
		fi
	elif [[ "${access_token_expired}" == "true" ]]; then
		if [[ "${remote_summary_json}" == "null" ]]; then
			remote_summary_status="unavailable_access_token_expired"
		else
			remote_summary_status="stale_access_token_expired"
		fi
	else
		if [[ "${remote_summary_json}" == "null" ]]; then
			remote_summary_status="unavailable_refresh_token_expired"
		else
			remote_summary_status="stale_refresh_token_expired"
		fi
	fi

	PATREAGE__STATUS_JSON="$(
		printf '%s\n' "${state_json}" | jq \
			--arg state_file "$(patreage__state_file)" \
			--arg remote_summary_status "${remote_summary_status}" \
			--arg remote_summary_error "${remote_summary_error}" \
			--arg remote_summary_fetched_at "${remote_summary_fetched_at}" \
			--argjson remote_summary "${remote_summary_json}" \
			'
      def parse_time:
        if endswith("+00:00") then .[0:(length - 6)] + "Z" else . end
        | if endswith("Z") and (index(".") != null) then .[0:index(".")] + "Z" else . end
        | fromdateiso8601;
      . as $state
      | ($state.refresh_token_expires_at | parse_time) as $refresh_expiry
      | ($state.access_token_expires_at | parse_time) as $access_expiry
      | {
          authenticated: (now < $refresh_expiry),
          api_base_url: $state.api_base_url,
          broker_session_id: $state.broker_session_id,
          access_token_expires_at: $state.access_token_expires_at,
          refresh_token_expires_at: $state.refresh_token_expires_at,
          access_token_expired: (now >= $access_expiry),
          refresh_token_expired: (now >= $refresh_expiry),
          remote_summary_status: $remote_summary_status,
          remote_summary_error: (
            if $remote_summary_error == ""
            then null
            else $remote_summary_error
            end
          ),
          remote_summary_fetched_at: (
            if $remote_summary_fetched_at == ""
            then null
            else $remote_summary_fetched_at
            end
          ),
          remote_summary: $remote_summary,
          state_file: $state_file,
          written_at: $state.written_at
        }
    '
	)"

	if [[ "${refresh_token_expired}" == "false" ]]; then
		PATREAGE__STATUS_EXIT=0
	else
		PATREAGE__STATUS_EXIT=1
	fi
	return 0
}

patreage__cmd_status() {
	if (($# > 0)); then
		patreage__warn "status does not accept arguments"
		exit "${PATREAGE__EXIT_USAGE}"
	fi

	patreage__require_command jq
	patreage__collect_status
	printf '%s\n' "${PATREAGE__STATUS_JSON}"
	exit "${PATREAGE__STATUS_EXIT}"
}
