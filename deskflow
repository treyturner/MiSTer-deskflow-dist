# Begin generated content from clients/shell/commands/logout.sh
patreage__cmd_logout() {
	local state_json
	local refresh_token=""
	local session_api_base_url=""
	local logout_payload

	if (($# > 0)); then
		patreage__warn "logout does not accept arguments"
		exit "${PATREAGE__EXIT_USAGE}"
	fi

	patreage__require_command jq
	patreage__require_command curl

	if patreage__state_file_exists; then
		if state_json="$(patreage__read_state_json)"; then
			if printf '%s\n' "${state_json}" | jq empty >/dev/null 2>&1; then
				refresh_token="$(printf '%s\n' "${state_json}" | jq -r '.refresh_token // empty')"
				session_api_base_url="$(printf '%s\n' "${state_json}" | jq -r '.api_base_url // empty')"
			else
				patreage__warn "local session state is malformed; removing it"
			fi
		else
			patreage__warn "local session state permissions are invalid; removing it"
		fi
	else
		patreage__note "No local session state found."
		exit 0
	fi

	if [[ -n "${refresh_token}" ]]; then
		logout_payload="$(jq -n --arg refresh_token "${refresh_token}" '{refresh_token: $refresh_token}')"
		if patreage__api_request_json "POST" "/v1/broker-sessions/logout" "${logout_payload}" "" "${session_api_base_url}"; then
			if [[ "${PATREAGE__HTTP_RESPONSE_STATUS}" != "204" ]]; then
				patreage__warn "$(patreage__response_detail)"
			fi
		else
			patreage__warn "failed to reach API for remote logout; clearing local state anyway"
		fi
	fi

	if ! patreage__remove_state_file; then
		patreage__die "failed to remove local session state"
	fi

	patreage__note "Logged out."
}
