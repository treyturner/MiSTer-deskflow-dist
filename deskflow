patreage__clear_session_resolution() {
	PATREAGE__SESSION_STATE_JSON=""
	PATREAGE__SESSION_API_BASE_URL=""
	PATREAGE__SESSION_ACCESS_TOKEN=""
	PATREAGE__SESSION_ERROR_CODE=""
	PATREAGE__SESSION_ERROR_DETAIL=""
	PATREAGE__REFRESHED_STATE_JSON=""
}

patreage__refresh_broker_access_token() {
	local state_json="$1"
	local refresh_token
	local api_base_url
	local refresh_payload
	local updated_state_json

	PATREAGE__REFRESHED_STATE_JSON=""
	refresh_token="$(patreage__state_json_field "${state_json}" '.refresh_token')"
	api_base_url="$(patreage__state_json_field "${state_json}" '.api_base_url')"
	refresh_payload="$(jq -n --arg refresh_token "${refresh_token}" '{refresh_token: $refresh_token}')"

	if ! patreage__api_request_json "POST" "/v1/broker-sessions/refresh" "${refresh_payload}" "" "${api_base_url}"; then
		PATREAGE__SESSION_ERROR_CODE="$(patreage__machine_code credential_helper_codes refresh_failed)"
		PATREAGE__SESSION_ERROR_DETAIL="failed to reach the API to refresh the broker access token"
		return 1
	fi

	if [[ "${PATREAGE__HTTP_RESPONSE_STATUS}" != "200" ]]; then
		PATREAGE__SESSION_ERROR_CODE="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.error // empty')"
		if [[ -z "${PATREAGE__SESSION_ERROR_CODE}" ]]; then
			PATREAGE__SESSION_ERROR_CODE="$(patreage__machine_code credential_helper_codes refresh_failed)"
		fi
		PATREAGE__SESSION_ERROR_DETAIL="$(patreage__response_detail)"
		return 1
	fi

	updated_state_json="$(patreage__build_refreshed_state_json "${state_json}" "${PATREAGE__HTTP_RESPONSE_BODY}")"
	if ! patreage__write_state_json "${updated_state_json}"; then
		PATREAGE__SESSION_ERROR_CODE="$(patreage__machine_code credential_helper_codes refresh_failed)"
		PATREAGE__SESSION_ERROR_DETAIL="failed to persist refreshed local session state"
		return 1
	fi

	PATREAGE__REFRESHED_STATE_JSON="${updated_state_json}"
	return 0
}

patreage__resolve_repo_session() {
	local state_json
	local read_exit=0

	patreage__clear_session_resolution

	if state_json="$(patreage__read_state_json)"; then
		:
	else
		read_exit=$?
		if [[ "${read_exit}" -eq 2 ]]; then
			PATREAGE__SESSION_ERROR_CODE="invalid_state_permissions"
			PATREAGE__SESSION_ERROR_DETAIL="local session state permissions are invalid"
			return 1
		fi

		PATREAGE__SESSION_ERROR_CODE="$(patreage__machine_code credential_helper_codes not_logged_in)"
		PATREAGE__SESSION_ERROR_DETAIL="patreage login is required"
		return 1
	fi

	if ! printf '%s\n' "${state_json}" | jq empty >/dev/null 2>&1; then
		PATREAGE__SESSION_ERROR_CODE="invalid_state_json"
		PATREAGE__SESSION_ERROR_DETAIL="local session state is invalid"
		return 1
	fi

	if ! patreage__state_json_is_valid "${state_json}"; then
		PATREAGE__SESSION_ERROR_CODE="invalid_state_json"
		PATREAGE__SESSION_ERROR_DETAIL="local session state is invalid"
		return 1
	fi

	if patreage__state_timestamp_expired "${state_json}" "refresh_token_expires_at"; then
		PATREAGE__SESSION_ERROR_CODE="$(patreage__machine_code broker_refresh_error_codes expired_refresh_token)"
		PATREAGE__SESSION_ERROR_DETAIL="local broker session has expired; run patreage login again"
		return 1
	fi

	if patreage__state_timestamp_expired "${state_json}" "access_token_expires_at"; then
		if ! patreage__refresh_broker_access_token "${state_json}"; then
			return 1
		fi
		state_json="${PATREAGE__REFRESHED_STATE_JSON}"
	fi

	PATREAGE__SESSION_STATE_JSON="${state_json}"
	PATREAGE__SESSION_API_BASE_URL="$(patreage__state_json_field "${state_json}" '.api_base_url')"
	PATREAGE__SESSION_ACCESS_TOKEN="$(patreage__state_json_field "${state_json}" '.access_token')"
	return 0
}

patreage__repo_access_output_json() {
	local response_json="$1"
	local credential_context_url
	local helper_key
	local use_http_path_key
	local unset_helper_command
	local add_helper_command
	local use_http_path_command

	credential_context_url="$(printf '%s\n' "${response_json}" | jq -r '.credential_context_url')"
	if ! patreage__validate_github_clone_url "${credential_context_url}"; then
		patreage__die "unsafe credential context URL was returned by the API"
	fi

	helper_key="credential.${credential_context_url}.helper"
	use_http_path_key="credential.${credential_context_url}.useHttpPath"
	unset_helper_command="$(patreage__shell_join git config --global --unset-all "${helper_key}") || true"
	add_helper_command="$(patreage__shell_join git config --global --add "${helper_key}" "!patreage credential-helper")"
	use_http_path_command="$(patreage__shell_join git config --global "${use_http_path_key}" true)"

	printf '%s\n' "${response_json}" | jq \
		--arg unset_helper_command "${unset_helper_command}" \
		--arg add_helper_command "${add_helper_command}" \
		--arg use_http_path_command "${use_http_path_command}" \
		'
      . + {
        git_config_commands: [
          $unset_helper_command,
          $add_helper_command,
          $use_http_path_command
        ]
      }
    '
}

patreage__credential_helper_mismatch_code() {
	local protocol="$1"
	local host="$2"

	if [[ "${protocol}" != "${PATREAGE__REPO_ACCESS_PROTOCOL}" ]]; then
		patreage__machine_code credential_helper_codes protocol_mismatch
		return 0
	fi
	if [[ "${host}" != "${PATREAGE__REPO_ACCESS_HOST}" ]]; then
		patreage__machine_code credential_helper_codes host_mismatch
		return 0
	fi

	printf '\n'
}

patreage__credential_helper_print_error() {
	local code="$1"
	local detail="$2"

	if [[ -z "${code}" ]]; then
		code="$(patreage__machine_code credential_helper_codes request_failed)"
	fi
	if [[ -z "${detail}" ]]; then
		detail="request failed"
	fi

	printf 'error: %s [%s]\n' "${detail}" "${code}" >&2
}

patreage__repo_access_json_request_or_die() {
	local endpoint_path="$1"
	local payload="$2"
	local error_code=""

	patreage__require_command jq
	patreage__require_command curl

	if ! patreage__resolve_repo_session; then
		patreage__die "${PATREAGE__SESSION_ERROR_DETAIL}"
	fi

	if ! patreage__api_request_json \
		"POST" \
		"${endpoint_path}" \
		"${payload}" \
		"${PATREAGE__SESSION_ACCESS_TOKEN}" \
		"${PATREAGE__SESSION_API_BASE_URL}"; then
		patreage__die "failed to contact API at ${PATREAGE__SESSION_API_BASE_URL}"
	fi

	if [[ "${PATREAGE__HTTP_RESPONSE_STATUS}" != "200" ]]; then
		error_code="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.error // empty')"
		if [[ -n "${error_code}" ]]; then
			patreage__die "$(patreage__response_detail) [${error_code}]"
		fi
		patreage__die "$(patreage__response_detail)"
	fi
}

patreage__repo_access_normalize_contents_path() {
	local raw_path="$1"

	case "${raw_path}" in
	"" | "." | "/")
		printf '\n'
		;;
	*)
		printf '%s\n' "${raw_path#"/"}"
		;;
	esac
}

patreage__repo_access_payload_with_repo() {
	local payload="$1"
	local repo_selector="${2:-}"

	if [[ -z "${repo_selector}" ]]; then
		printf '%s\n' "${payload}"
		return 0
	fi

	printf '%s\n' "${payload}" | jq \
		--arg repo "${repo_selector}" \
		'. + {repo: $repo}'
}

patreage__repo_access_download_archive() {
	local download_url="$1"
	local output_mode="$2"
	local output_path="${3:-}"
	local temp_file=""
	local output_dir=""

	if ! patreage__validate_github_https_url "${download_url}"; then
		patreage__die "unsafe archive download URL was returned by the API"
	fi

	if [[ "${output_mode}" == "stdout" ]]; then
		if [[ -t 1 ]]; then
			patreage__die "refusing to write archive bytes to an interactive terminal; use --output PATH or pipe --stdout"
		fi
		if ! curl -fsSL --proto '=https' --proto-redir '=https' "${download_url}"; then
			patreage__die "failed to download archive"
		fi
		return 0
	fi

	output_dir="$(dirname -- "${output_path}")"
	temp_file="$(mktemp "${output_dir}/patreage-archive.XXXXXX")" || {
		patreage__die "failed to create a temporary archive file in ${output_dir}"
	}

	if ! curl -fsSL --proto '=https' --proto-redir '=https' --output "${temp_file}" "${download_url}"; then
		rm -f "${temp_file}"
		patreage__die "failed to download archive"
	fi

	if ! mv -f "${temp_file}" "${output_path}"; then
		rm -f "${temp_file}"
		patreage__die "failed to move the archive into place at ${output_path}"
	fi
}

patreage__repo_access_release_failure_json() {
	local repo_selector="$1"
	local release_tag="$2"
	local asset_name="$3"
	local output_path="$4"
	local result_code="$5"
	local detail="$6"
	local http_status_json="$7"

	jq -n \
		--arg result_code "${result_code}" \
		--arg repo "${repo_selector}" \
		--arg tag "${release_tag}" \
		--arg asset "${asset_name}" \
		--arg output "${output_path}" \
		--arg detail "${detail}" \
		--argjson http_status "${http_status_json}" \
		'{
      ok: false,
      result_code: $result_code,
      repo: $repo,
      tag: $tag,
      asset: $asset,
      output: $output,
      detail: $detail,
      http_status: $http_status
    }'
}

patreage__repo_access_release_success_json() {
	local repo_selector="$1"
	local release_tag="$2"
	local asset_name="$3"
	local output_path="$4"
	local bytes_written="$5"
	local result_code

	result_code="$(patreage__machine_code repo_access_release_result_codes asset_downloaded)"
	jq -n \
		--arg result_code "${result_code}" \
		--arg repo "${repo_selector}" \
		--arg tag "${release_tag}" \
		--arg asset "${asset_name}" \
		--arg output "${output_path}" \
		--argjson bytes_written "${bytes_written}" \
		'{
      ok: true,
      result_code: $result_code,
      repo: $repo,
      tag: $tag,
      asset: $asset,
      output: $output,
      bytes_written: $bytes_written
    }'
}

patreage__repo_access_release_http_status_json() {
	local http_status="$1"

	if [[ "${http_status}" =~ ^[0-9]+$ && "${http_status}" != "000" ]]; then
		printf '%s\n' "${http_status}"
		return 0
	fi

	printf 'null\n'
}

patreage__repo_access_release_fail() {
	local json_output="$1"
	local repo_selector="$2"
	local release_tag="$3"
	local asset_name="$4"
	local output_path="$5"
	local result_code="$6"
	local detail="$7"
	local http_status="${8:-}"
	local http_status_json

	if [[ -z "${result_code}" ]]; then
		result_code="$(patreage__machine_code repo_access_release_error_codes download_failed)"
	fi
	if [[ -z "${detail}" ]]; then
		detail="release asset download failed"
	fi
	http_status_json="$(patreage__repo_access_release_http_status_json "${http_status}")"

	if [[ "${json_output}" == "1" ]]; then
		patreage__repo_access_release_failure_json \
			"${repo_selector}" \
			"${release_tag}" \
			"${asset_name}" \
			"${output_path}" \
			"${result_code}" \
			"${detail}" \
			"${http_status_json}"
	else
		printf 'error: %s [%s]\n' "${detail}" "${result_code}" >&2
	fi
	exit 1
}

patreage__repo_access_release_error_from_file() {
	local error_file="$1"
	local fallback_code

	fallback_code="$(patreage__machine_code repo_access_release_error_codes download_failed)"
	if jq -er '.error // empty' "${error_file}" >/dev/null 2>&1; then
		jq -r '.error' "${error_file}"
		return 0
	fi

	printf '%s\n' "${fallback_code}"
}

patreage__repo_access_release_detail_from_file() {
	local error_file="$1"

	if jq -er '.detail // empty' "${error_file}" >/dev/null 2>&1; then
		jq -r '.detail' "${error_file}"
		return 0
	fi

	printf 'release asset download failed\n'
}

patreage__repo_access_download_release_asset() {
	local payload="$1"
	local output_path="$2"
	local json_output="$3"
	local repo_selector="$4"
	local release_tag="$5"
	local asset_name="$6"
	local endpoint_path="/v1/repo-access/github-release/asset"
	local output_dir
	local temp_file=""
	local status_code=""
	local curl_exit=0
	local bytes_written
	local error_code
	local error_detail
	local url
	local -a curl_args

	patreage__require_command jq
	patreage__require_command curl

	output_dir="$(dirname -- "${output_path}")"
	temp_file="$(mktemp "${output_dir}/patreage-release-asset.XXXXXX")" || {
		patreage__repo_access_release_fail \
			"${json_output}" \
			"${repo_selector}" \
			"${release_tag}" \
			"${asset_name}" \
			"${output_path}" \
			"$(patreage__machine_code repo_access_release_error_codes download_failed)" \
			"failed to create a temporary release asset file in ${output_dir}" \
			""
	}

	if ! patreage__resolve_repo_session; then
		rm -f "${temp_file}"
		patreage__repo_access_release_fail \
			"${json_output}" \
			"${repo_selector}" \
			"${release_tag}" \
			"${asset_name}" \
			"${output_path}" \
			"${PATREAGE__SESSION_ERROR_CODE}" \
			"${PATREAGE__SESSION_ERROR_DETAIL}" \
			""
	fi

	url="${PATREAGE__SESSION_API_BASE_URL}${endpoint_path}"
	curl_args=(
		-sS
		-o "${temp_file}"
		-w '%{http_code}'
		-X POST
		-H 'Accept: application/octet-stream'
		-H 'Content-Type: application/json'
		-H "Authorization: Bearer ${PATREAGE__SESSION_ACCESS_TOKEN}"
		--data "${payload}"
		"${url}"
	)

	if status_code="$(curl "${curl_args[@]}")"; then
		curl_exit=0
	else
		curl_exit=$?
	fi

	if [[ "${curl_exit}" -ne 0 ]]; then
		rm -f "${temp_file}"
		patreage__repo_access_release_fail \
			"${json_output}" \
			"${repo_selector}" \
			"${release_tag}" \
			"${asset_name}" \
			"${output_path}" \
			"$(patreage__machine_code repo_access_release_error_codes download_failed)" \
			"failed to contact API at ${PATREAGE__SESSION_API_BASE_URL}" \
			""
	fi

	if [[ "${status_code}" != "200" ]]; then
		error_code="$(patreage__repo_access_release_error_from_file "${temp_file}")"
		error_detail="$(patreage__repo_access_release_detail_from_file "${temp_file}")"
		rm -f "${temp_file}"
		patreage__repo_access_release_fail \
			"${json_output}" \
			"${repo_selector}" \
			"${release_tag}" \
			"${asset_name}" \
			"${output_path}" \
			"${error_code}" \
			"${error_detail}" \
			"${status_code}"
	fi

	bytes_written="$(wc -c <"${temp_file}")"
	bytes_written="${bytes_written//[[:space:]]/}"
	if ! mv -f "${temp_file}" "${output_path}"; then
		rm -f "${temp_file}"
		patreage__repo_access_release_fail \
			"${json_output}" \
			"${repo_selector}" \
			"${release_tag}" \
			"${asset_name}" \
			"${output_path}" \
			"$(patreage__machine_code repo_access_release_error_codes download_failed)" \
			"failed to move the release asset into place at ${output_path}" \
			""
	fi

	if [[ "${json_output}" == "1" ]]; then
		patreage__repo_access_release_success_json \
			"${repo_selector}" \
			"${release_tag}" \
			"${asset_name}" \
			"${output_path}" \
			"${bytes_written}"
	fi
}
