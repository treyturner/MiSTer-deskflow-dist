	patreage__url_origin_from_parts \
		"${PATREAGE__PARSED_URL_SCHEME}" \
		"${PATREAGE__PARSED_URL_HOST}" \
		"${PATREAGE__PARSED_URL_PORT}"
}

patreage__validate_same_origin_auth_url() {
	local raw_url="$1"
	local base_url="$2"
	local url_origin
	local base_origin
	local scheme
	local path
	local query
	local fragment

	if ! patreage__parse_url "${raw_url}"; then
		return 1
	fi
	scheme="${PATREAGE__PARSED_URL_SCHEME}"
	path="${PATREAGE__PARSED_URL_PATH}"
	query="${PATREAGE__PARSED_URL_QUERY}"
	fragment="${PATREAGE__PARSED_URL_FRAGMENT}"
	if ! url_origin="$(patreage__url_origin_from_parts \
		"${PATREAGE__PARSED_URL_SCHEME}" \
		"${PATREAGE__PARSED_URL_HOST}" \
		"${PATREAGE__PARSED_URL_PORT}")"; then
		return 1
	fi
	if [[ "${scheme}" != "http" && "${scheme}" != "https" ]]; then
		return 1
	fi
	if [[ "${path}" != "/auth/verify" && "${path}" != /auth/verify/* ]]; then
		return 1
	fi
	if [[ -n "${query}" || -n "${fragment}" ]]; then
		return 1
	fi

	if ! patreage__parse_url "${base_url}"; then
		return 1
	fi
	if ! base_origin="$(patreage__url_origin_from_parts \
		"${PATREAGE__PARSED_URL_SCHEME}" \
		"${PATREAGE__PARSED_URL_HOST}" \
		"${PATREAGE__PARSED_URL_PORT}")"; then
		return 1
	fi

	[[ "${url_origin}" == "${base_origin}" ]]
}

patreage__validate_github_https_url() {
	local raw_url="$1"
	local host

	if ! patreage__parse_url "${raw_url}"; then
		return 1
	fi
	if [[ "${PATREAGE__PARSED_URL_SCHEME}" != "https" ]]; then
		return 1
	fi
	host="${PATREAGE__PARSED_URL_HOST}"
	if [[ "${host}" != "github.com" && "${host}" != "codeload.github.com" ]]; then
		return 1
	fi
	if ! patreage__url_uses_default_port "${PATREAGE__PARSED_URL_SCHEME}" "${PATREAGE__PARSED_URL_PORT}"; then
		return 1
	fi
	if [[ -z "${PATREAGE__PARSED_URL_PATH}" || "${PATREAGE__PARSED_URL_PATH}" == "/" ]]; then
		return 1
	fi
	return 0
}

patreage__validate_github_clone_url() {
	local raw_url="$1"
	local repo_path
	local owner
	local repo_name

	if ! patreage__validate_github_https_url "${raw_url}"; then
		return 1
	fi
	if [[ "${PATREAGE__PARSED_URL_HOST}" != "github.com" ]]; then
		return 1
	fi
	if [[ -n "${PATREAGE__PARSED_URL_QUERY}" || -n "${PATREAGE__PARSED_URL_FRAGMENT}" ]]; then
		return 1
	fi

	repo_path="${PATREAGE__PARSED_URL_PATH#/}"
	if [[ "${repo_path}" != */*.git || "${repo_path}" == */*/* ]]; then
		return 1
	fi
	owner="${repo_path%%/*}"
	repo_name="${repo_path#*/}"
	repo_name="${repo_name%.git}"
	if [[ -z "${owner}" || -z "${repo_name}" ]]; then
		return 1
	fi
	if [[ "${owner}" == "." || "${owner}" == ".." || "${repo_name}" == "." || "${repo_name}" == ".." ]]; then
		return 1
	fi
	if [[ ! "${owner}" =~ ^[A-Za-z0-9_.-]+$ || ! "${repo_name}" =~ ^[A-Za-z0-9_.-]+$ ]]; then
		return 1
	fi
	return 0
}

patreage__shell_quote() {
	local value="$1"
	local escaped

	if [[ -n "${value}" && "${value}" =~ ^[A-Za-z0-9_@%+=:,./-]+$ ]]; then
		printf '%s' "${value}"
		return 0
	fi

	escaped=${value//\'/\'\\\'\'}
	printf "'%s'" "${escaped}"
}

patreage__shell_join() {
	local joined=""
	local quoted
	local arg

	for arg in "$@"; do
		quoted="$(patreage__shell_quote "${arg}")"
		if [[ -z "${joined}" ]]; then
			joined="${quoted}"
		else
			joined="${joined} ${quoted}"
		fi
	done

	printf '%s\n' "${joined}"
}
