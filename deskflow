# deskflow - MiSTer Deskflow entrypoint. Run 'deskflow help' for usage.

set -euo pipefail

resolve_entrypoint_path() {
  local invoked="${BASH_SOURCE[0]:-$0}"
  local candidate=""
  local dir=""

  case "${invoked}" in
    */*) candidate="${invoked}" ;;
    *) candidate="$(command -v "${invoked}" 2>/dev/null || true)" ;;
  esac
  [[ -n "${candidate}" ]] || candidate="${invoked}"

  dir="$(cd "$(dirname "${candidate}")" 2>/dev/null && pwd)" || return 1
  printf '%s/%s\n' "${dir}" "$(basename "${candidate}")"
}

ENTRYPOINT_PATH="$(resolve_entrypoint_path || printf '%s\n' "$0")"
SCRIPT_DIR="$(cd "$(dirname "${ENTRYPOINT_PATH}")" && pwd)"
INSTALL_DIR="${INSTALL_DIR:-/media/fat/Scripts/deskflow-dist}"
PREVIEW_RELEASE_REPO="treyturner/MiSTer-deskflow-dist-preview"
DESKFLOW_ENTRYPOINT_SHA256="71b9e329aed76c948b913e8deb0e6a66994fe06268ef14c9b035f735b99c3761"
DESKFLOW_UPDATE_INTERVAL_SECONDS=86400

info() { printf '%s\n' "$*"; }
error() { printf '%s\n' "$*" >&2; }
die() { error "$*"; exit 1; }

# Some MiSTer images only ship a flat CA bundle, while curl/OpenSSL default to
# a hashed certificate directory. Point both at a readable bundle file when we
# can find one so HTTPS bootstrap continues to work.
configure_ssl_cert_env() {
  local ca_bundle=""

  if [[ -n "${CURL_CA_BUNDLE:-}" ]] && [[ -r "${CURL_CA_BUNDLE}" ]]; then
    ca_bundle="${CURL_CA_BUNDLE}"
  elif [[ -n "${SSL_CERT_FILE:-}" ]] && [[ -r "${SSL_CERT_FILE}" ]]; then
    ca_bundle="${SSL_CERT_FILE}"
  else
    for ca_bundle in \
      /etc/ssl/certs/cacert.pem \
      /etc/ssl/cert.pem \
      /etc/ssl/certs/ca-certificates.crt \
      /etc/ssl/certs/ca-bundle.crt \
      /etc/pki/tls/certs/ca-bundle.crt
    do
      if [[ -r "${ca_bundle}" ]]; then
        break
      fi
      ca_bundle=""
    done
  fi

  if [[ -n "${ca_bundle}" ]]; then
    export SSL_CERT_FILE="${ca_bundle}"
    export CURL_CA_BUNDLE="${ca_bundle}"
  fi
}

configure_ssl_cert_env

is_installed() {
  [[ -f "${INSTALL_DIR}/.channel" ]]
}

self_update_current_epoch() {
  date +%s 2>/dev/null || printf '0\n'
}

self_update_marker_path() {
  printf '%s/.installer-updated\n' "${INSTALL_DIR}"
}

self_update_should_defer() {
  local marker=""
  local now=0
  local updated_at=0

  is_installed || return 1

  marker="$(self_update_marker_path)"
  [[ -f "${marker}" ]] || return 1

  updated_at="$(sed -n '1p' "${marker}" 2>/dev/null || true)"
  [[ "${updated_at}" =~ ^[0-9]+$ ]] || return 1

  now="$(self_update_current_epoch)"
  [[ "${now}" =~ ^[0-9]+$ ]] || return 1

  ((now >= updated_at)) || return 1
  ((now - updated_at < DESKFLOW_UPDATE_INTERVAL_SECONDS))
}

self_update_write_marker() {
  local marker=""
  local now=0

  is_installed || return 0

  marker="$(self_update_marker_path)"
  now="$(self_update_current_epoch)"
  [[ "${now}" =~ ^[0-9]+$ ]] || return 0

  if ! { printf '%s\n' "${now}" >"${marker}"; } 2>/dev/null; then
    :
  fi
}

self_update_read_sha256() {
  local file=$1

  sed -n 's/^\([[:xdigit:]]\{64\}\).*$/\1/p' "${file}" 2>/dev/null \
    | head -1 \
    | tr '[:upper:]' '[:lower:]'
}

self_update_embedded_sha256() {
  local file=$1

  sed -n 's/^DESKFLOW_ENTRYPOINT_SHA256="\([[:xdigit:]]\{64\}\)".*$/\1/p' "${file}" 2>/dev/null \
    | head -1 \
    | tr '[:upper:]' '[:lower:]'
}

self_update_entrypoint() {
  local work_dir=""
  local remote_sha_file=""
  local remote_script=""
  local remote_sha=""
  local embedded_sha=""

  [[ "${DESKFLOW_SELF_UPDATE_ATTEMPTED:-0}" != "1" ]] || return 0
  [[ ! -f "${SCRIPT_DIR}/patreage-download.sh" ]] || return 0
  self_update_should_defer && return 0

  work_dir="$(mktemp -d 2>/dev/null)" || return 0
  remote_sha_file="${work_dir}/deskflow.sha256"
  remote_script="${work_dir}/deskflow"

  if ! curl -fsSL --retry 3 -o "${remote_sha_file}" "https://raw.githubusercontent.com/treyturner/MiSTer-deskflow-dist/main/deskflow.sha256" >/dev/null 2>&1; then
    rm -rf "${work_dir}"
    return 0
  fi

  remote_sha="$(self_update_read_sha256 "${remote_sha_file}")"
  if [[ ! "${remote_sha}" =~ ^[0-9a-f]{64}$ ]]; then
    rm -rf "${work_dir}"
    return 0
  fi

  if [[ "${DESKFLOW_ENTRYPOINT_SHA256}" == "${remote_sha}" ]]; then
    self_update_write_marker
    rm -rf "${work_dir}"
    return 0
  fi

  if ! curl -fsSL --retry 3 -o "${remote_script}" "https://raw.githubusercontent.com/treyturner/MiSTer-deskflow-dist/main/deskflow" >/dev/null 2>&1; then
    rm -rf "${work_dir}"
    return 0
  fi
  if [[ ! -s "${remote_script}" ]]; then
    rm -rf "${work_dir}"
    return 0
  fi
  if ! bash -n "${remote_script}" >/dev/null 2>&1; then
    rm -rf "${work_dir}"
    return 0
  fi

  embedded_sha="$(self_update_embedded_sha256 "${remote_script}")"
  if [[ "${embedded_sha}" != "${remote_sha}" ]]; then
    rm -rf "${work_dir}"
    return 0
  fi

  chmod 0755 "${remote_script}" 2>/dev/null || true
  if ! mv -f "${remote_script}" "${ENTRYPOINT_PATH}" 2>/dev/null; then
    rm -rf "${work_dir}"
    return 0
  fi

  self_update_write_marker
  rm -rf "${work_dir}"
  info "Updated entrypoint; restarting..."

  export DESKFLOW_SELF_UPDATE_ATTEMPTED=1
  shopt -s execfail
  if ! exec "${ENTRYPOINT_PATH}" "$@"; then
    return 0
  fi
}

self_update_entrypoint "$@" || true

