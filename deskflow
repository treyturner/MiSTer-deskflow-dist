}

patreage__doctor_skipped_repo_result_json() {
	local selector_json="$1"
	local target="$2"
	local repo_status="$3"
	local error_code="$4"
	local detail="$5"

	patreage__doctor_repo_result_json \
		"${selector_json}" \
		"${target}" \
		"${repo_status}" \
		"null" \
		"${error_code}" \
		"${detail}" \
		"{}" \
		"not_attempted"
