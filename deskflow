	filter='{file:(.state_file // $state_file),status:(if (.reason // "") == "not_logged_in" then "missing" elif (.reason // "") == "invalid_state_permissions" then "error" elif (.reason // "") == "invalid_state_json" then "error" else "ok" end),reason:(.reason // null),written_at:(.written_at // null)}'
	printf '%s\n' "${status_json}" | jq \
		--arg state_file "$(patreage__state_file)" \
