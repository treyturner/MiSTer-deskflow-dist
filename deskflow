patreage__parse_url() {
	local raw_url="$1"
	local scheme
	local remainder
	local authority
	local suffix
	local path_and_query
	local host
	local port=""

	patreage__clear_parsed_url

	if [[ -z "${raw_url}" || "${raw_url}" != *"://"* ]]; then
		return 1
	fi
	if patreage__string_has_control_chars "${raw_url}" || patreage__string_has_url_whitespace "${raw_url}"; then
		return 1
	fi

	scheme="${raw_url%%://*}"
	remainder="${raw_url#*://}"
	if [[ ! "${scheme}" =~ ^[A-Za-z][A-Za-z0-9+.-]*$ ]]; then
		return 1
	fi

	authority="${remainder%%[/?#]*}"
	suffix="${remainder:${#authority}}"
	if [[ -z "${authority}" || "${authority}" == *"@"* ]]; then
		return 1
	fi

	host="${authority}"
	if [[ "${authority}" == *":"* ]]; then
		host="${authority%%:*}"
		port="${authority#*:}"
		if [[ -z "${port}" || ! "${port}" =~ ^[0-9]+$ ]]; then
			return 1
		fi
	fi
	if [[ -z "${host}" || "${host}" == *":"* ]]; then
		return 1
	fi

	path_and_query="${suffix%%#*}"
	PATREAGE__PARSED_URL_FRAGMENT=""
	if [[ "${suffix}" == *"#"* ]]; then
		PATREAGE__PARSED_URL_FRAGMENT="${suffix#*#}"
	fi
	PATREAGE__PARSED_URL_QUERY=""
	if [[ "${path_and_query}" == *"?"* ]]; then
		PATREAGE__PARSED_URL_QUERY="${path_and_query#*\?}"
	fi

	PATREAGE__PARSED_URL_SCHEME="${scheme,,}"
	PATREAGE__PARSED_URL_HOST="${host,,}"
	PATREAGE__PARSED_URL_PORT="${port}"
	PATREAGE__PARSED_URL_PATH="${path_and_query%%\?*}"
	return 0
}

patreage__default_port_for_scheme() {
	local scheme="$1"

	case "${scheme}" in
	http)
		printf '80\n'
		;;
	https)
		printf '443\n'
		;;
	*)
		printf '\n'
		;;
	esac
}

patreage__url_uses_default_port() {
	local scheme="$1"
	local port="$2"
	local default_port

	if [[ -z "${port}" ]]; then
		return 0
	fi

	default_port="$(patreage__default_port_for_scheme "${scheme}")"
	[[ -n "${default_port}" && "${port}" == "${default_port}" ]]
}

patreage__url_origin_from_parts() {
	local scheme="$1"
	local host="$2"
	local port="$3"

	if [[ -z "${port}" ]]; then
		port="$(patreage__default_port_for_scheme "${scheme}")"
	fi
	if [[ -z "${port}" ]]; then
		return 1
	fi

	printf '%s://%s:%s\n' "${scheme}" "${host}" "${port}"
}

patreage__normalized_url_origin() {
	local raw_url="$1"

	if ! patreage__parse_url "${raw_url}"; then
		return 1
