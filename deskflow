patreage__api_request_json() {
	local method="$1"
	local path="$2"
	local payload="${3:-}"
	local access_token="${4:-}"
	local base_url="${5:-}"
	local body_file
	local curl_exit=0
	local status_code=""
	local url
	local -a curl_args

	patreage__require_command curl

	if [[ -z "${base_url}" ]]; then
		base_url="$(patreage__api_public_base_url)"
	fi
	url="${base_url}${path}"
	body_file="$(mktemp)"
	curl_args=(
		-sS
		-o "${body_file}"
		-w '%{http_code}'
		-X "${method}"
		-H 'Accept: application/json'
	)
	if [[ -n "${payload}" ]]; then
		curl_args+=(
			-H 'Content-Type: application/json'
			--data "${payload}"
		)
	fi
	if [[ -n "${access_token}" ]]; then
		curl_args+=(-H "Authorization: Bearer ${access_token}")
	fi
	curl_args+=("${url}")

	if status_code="$(curl "${curl_args[@]}")"; then
		curl_exit=0
	else
		curl_exit=$?
	fi

	PATREAGE__HTTP_RESPONSE_BODY="$(cat "${body_file}")"
	PATREAGE__HTTP_RESPONSE_STATUS="${status_code}"
	rm -f "${body_file}"

	if [[ "${curl_exit}" -ne 0 ]]; then
		return "${curl_exit}"
	fi
	return 0
}

patreage__response_detail() {
	if [[ -z "${PATREAGE__HTTP_RESPONSE_BODY}" ]]; then
		printf 'request failed\n'
		return 0
	fi

	if printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -er '.detail' >/dev/null 2>&1; then
		printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.detail'
		return 0
	fi

	printf 'request failed\n'
}
