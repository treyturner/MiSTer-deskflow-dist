#!/usr/bin/env bash
# shellcheck shell=bash
# SPDX-FileCopyrightText: (C) 2026 Trey Turner
# SPDX-License-Identifier: MIT

# Deskflow integration helpers for Patreage-brokered preview release assets.
# Source this from deskflow/install-deskflow after defining SCRIPT_DIR,
# PREVIEW_RELEASE_REPO, info(), and die(). WORK_DIR must be set before calling
# download_preview_release_asset.

ensure_patreage_module() {
  if declare -F patreage_client >/dev/null 2>&1; then
    return 0
  fi

  local module_path="${SCRIPT_DIR}/armhf/vendor/patreage/clients/shell/dist/patreage-module.sh"
  if [[ ! -r "${module_path}" ]]; then
    die "Patreage module not found. Regenerate the published scripts with armhf/package.sh."
  fi

  # shellcheck source=/dev/null
  . "${module_path}"
}

patreage_state_file_path() {
  ensure_patreage_module
  patreage__initialize_module_state
  patreage__state_file
}

verify_preview_repo_access() {
  ensure_patreage_module
  patreage_client repo-access --repo "${PREVIEW_RELEASE_REPO}" >/dev/null \
    || die "You don't appear to have access."
}

ensure_preview_auth() {
  ensure_patreage_module
  patreage_require_runtime

  if ! patreage_client status >/dev/null 2>&1; then
    info "Preview builds require Patreage sign-in."
    patreage_client login
  fi

  verify_preview_repo_access
}

is_preview_release_asset() {
  local repo="$1"
  local tag="$2"
  [[ "${repo}" == "${PREVIEW_RELEASE_REPO}" ]] \
    && [[ -n "${tag}" ]]
}

die_from_patreage_release_json() {
  local tag=$1
  local asset_name=$2
  local json_file=$3
  local stderr_file=$4
  local result_code=""
  local detail=""
  local http_status=""
  local stderr_line=""
  local message

  if jq -e '.ok == false' "${json_file}" >/dev/null 2>&1; then
    result_code="$(jq -r '.result_code // empty' "${json_file}")"
    detail="$(jq -r '.detail // empty' "${json_file}")"
    http_status="$(jq -r '.http_status // empty' "${json_file}")"
  fi

  stderr_line="$(sed -n '1p' "${stderr_file}" 2>/dev/null || true)"
  [[ -n "${detail}" ]] || detail="${stderr_line:-release asset download failed}"
  [[ -n "${result_code}" ]] || result_code="unknown"

  message="Failed to download preview asset '${asset_name}' from '${tag}': ${detail} [${result_code}]"
  if [[ -n "${http_status}" && "${http_status}" != "null" ]]; then
    message="${message} (HTTP ${http_status})"
  fi
  die "${message}"
}

download_preview_release_asset() {
  local tag=$1
  local asset_name=$2
  local dest=$3
  local json_file
  local stderr_file
  local exit_code=0
  local stderr_line=""

  ensure_patreage_module
  patreage_require_runtime

  json_file="$(mktemp "${WORK_DIR}/patreage-release-result.XXXXXX")"
  stderr_file="$(mktemp "${WORK_DIR}/patreage-release-error.XXXXXX")"

  if patreage_client repo-access github-release \
    --repo "${PREVIEW_RELEASE_REPO}" \
    --tag "${tag}" \
    --asset "${asset_name}" \
    --output "${dest}" \
    --json >"${json_file}" 2>"${stderr_file}"; then
    rm -f "${json_file}" "${stderr_file}"
    return 0
  else
    exit_code=$?
  fi

  if [[ "${exit_code}" -eq 64 ]]; then
    stderr_line="$(sed -n '1p' "${stderr_file}" 2>/dev/null || true)"
    die "Patreage release download usage error for '${asset_name}' from '${tag}': ${stderr_line:-exit 64}"
  fi

  die_from_patreage_release_json "${tag}" "${asset_name}" "${json_file}" "${stderr_file}"
}
# __DESKFLOW_PATREAGE_HELPER_INLINE_END__

if ! declare -F download_preview_release_asset >/dev/null 2>&1; then
  # shellcheck source=deploy/linux/mister/patreage-download.sh
  . "${SCRIPT_DIR}/patreage-download.sh"
fi

is_preview_channel() {
  [[ "${1:-}" == "preview" ]]
}

selector_url_for_channel() {
  local channel=$1

  printf '%s/channels/%s.json\n' "https://raw.githubusercontent.com/treyturner/MiSTer-deskflow-dist/main" "${channel}"
}

fetch_channel_selector() {
  local channel=$1
  local dest=$2
  local selector_url
  local selector_http

  selector_url=$(selector_url_for_channel "${channel}")
  info "Fetching channel selector: ${selector_url}"

  selector_http=$(curl -sSL -o "${dest}" -w '%{http_code}' "${selector_url}")

  case "${selector_http}" in
    200) ;;
    401|403)
      die "Access denied fetching channel '${channel}' from ${selector_url}"
      ;;
    404)
      die "Channel '${channel}' not found at ${selector_url}"
      ;;
    *)
      die "Failed to fetch channel selector from ${selector_url} (HTTP ${selector_http})"
      ;;
  esac
}

show_help() {
  printf 'MiSTer Deskflow - keyboard and mouse sharing for MiSTer FPGA\n'
  printf '\n'
  if [ -f "${INSTALL_DIR}/.channel" ]; then
    printf 'Usage: deskflow <command> [args]\n'
    printf '\n'
    printf 'Commands:\n'
    printf '  install [CHANNEL]    Install or reinstall (default channel: latest)\n'
    printf '  update               Check and apply any available updates\n'
    printf '  start                Start deskflow-core in the background\n'
    printf '  run                  Run deskflow-core in the foreground\n'
    printf '  stop                 Stop deskflow-core\n'
    printf '  configure            Open GUI configuration\n'
    printf '  configure-from-cli   Edit deskflow.conf in a text editor\n'
    printf '  fingerprint-trust    Persist strict, tofu, or promiscuous for future launches\n'
    printf '  show-fingerprint-trust  Show current fingerprint-trust mode\n'
    printf '  enable-autostart     Enable automatic startup on network up\n'
    printf '  disable-autostart    Disable automatic startup on network up\n'
    printf '  remove               Stop and uninstall Deskflow\n'
    printf '  status               Show channel, version, service state, and bundle info\n'
    printf '  preview-login        Sign in with Patreage and verify preview access\n'
    printf '  preview-logout       Revoke and clear the Patreage session\n'
    printf '  preview-status       Show Patreage diagnostics and preview access state\n'
    printf '  help                 Show this help\n'
  else
    printf 'Deskflow is not installed.\n'
    printf '\n'
    printf 'Usage: deskflow install [CHANNEL]\n'
    printf '\n'
    printf 'Commands:\n'
    printf '  install [CHANNEL]    Download and install (default channel: latest)\n'
    printf '  preview-login        Sign in with Patreage and verify preview access\n'
    printf '  preview-logout       Revoke and clear the Patreage session\n'
    printf '  preview-status       Show Patreage diagnostics and preview access state\n'
    printf '  help                 Show this help\n'
  fi
}

download() {
  local url=$1
  local dest=$2
  curl -fsSL --retry 3 -o "${dest}" "${url}"
}

sha256_file() {
  local f=$1
  sha256sum "${f}" | cut -d' ' -f1
}

find_text_editor() {
  if [ -n "${VISUAL:-}" ] && command -v "${VISUAL}" >/dev/null 2>&1; then
    printf '%s\n' "${VISUAL}"
    return 0
  fi
  if [ -n "${EDITOR:-}" ] && command -v "${EDITOR}" >/dev/null 2>&1; then
    printf '%s\n' "${EDITOR}"
    return 0
  fi
  if [ -e "${HOME}/.viminfo" ] && command -v vi >/dev/null 2>&1; then
    printf 'vi\n'
    return 0
  fi
  if command -v nano >/dev/null 2>&1; then
    printf 'nano\n'
    return 0
  fi
  if command -v vi >/dev/null 2>&1; then
    printf 'vi\n'
    return 0
  fi
  return 1
}

# Parse a top-level JSON string value by key.
# Usage: json_get KEY FILE
json_get() {
  local key=$1
  local file=$2
  jq -r ".${key} // empty" "${file}"
}

# Parse a JSON string value from within a named subsection.
# Usage: json_section_get SECTION KEY FILE
json_section_get() {
  local sec=$1
  local key=$2
  local file=$3
  jq -r ".tracks.${sec}.${key} // .${sec}.${key} // empty" "${file}"
}

release_tag_from_manifest_url() {
  local url="$1"
  printf '%s\n' "${url}" \
    | sed -n 's|.*/releases/download/\([^/]*\)/[^/]*$|\1|p' \
    | head -1
}

release_repo_from_manifest_url() {
  local url="$1"
  printf '%s\n' "${url}" \
    | sed -n 's|https://github.com/\([^/]*/[^/]*\)/releases/download/.*|\1|p' \
    | head -1
}

show_preview_status() {
  local have_jq=0
  local have_curl=0
  local state_file=""
  local status_json=""
  local status_err
  local access_err
  local authenticated="false"
  local reason=""
  local remote_summary_status=""
  local error_line=""

  ensure_patreage_module

  info "Dependencies:"
  info "  bash: ${BASH_VERSION}"
  if command -v jq >/dev/null 2>&1; then
    have_jq=1
    info "  jq: $(jq --version)"
  else
    info "  jq: missing"
  fi
  if command -v curl >/dev/null 2>&1; then
    have_curl=1
    info "  curl: $(curl --version 2>/dev/null | head -n 1)"
  else
    info "  curl: missing"
  fi

  state_file="$(patreage_state_file_path 2>/dev/null || true)"
  info "State file: ${state_file:-unknown}"

  if [[ "${have_jq}" -ne 1 ]]; then
    info "Patreage session: unavailable (missing jq)"
    info "Preview repo access: unavailable (missing jq)"
    return 0
  fi

  status_err="$(mktemp)"
  if status_json="$(patreage_client status 2>"${status_err}")"; then
    :
  fi

  authenticated="$(printf '%s\n' "${status_json}" | jq -r '.authenticated // false' 2>/dev/null || printf 'false')"
  reason="$(printf '%s\n' "${status_json}" | jq -r '.reason // empty' 2>/dev/null || true)"
  remote_summary_status="$(printf '%s\n' "${status_json}" | jq -r '.remote_summary_status // empty' 2>/dev/null || true)"

  if [[ "${authenticated}" == "true" ]]; then
    if [[ -n "${remote_summary_status}" ]]; then
      info "Patreage session: authenticated (${remote_summary_status})"
    else
      info "Patreage session: authenticated"
    fi
  else
    [[ -n "${reason}" ]] || reason="not_logged_in"
    info "Patreage session: not authenticated (${reason})"
  fi
  rm -f "${status_err}"

  if [[ "${have_curl}" -ne 1 ]]; then
    info "Preview repo access: unavailable (missing curl)"
    return 0
  fi
  if [[ "${authenticated}" != "true" ]]; then
    info "Preview repo access: not checked (not authenticated)"
    return 0
  fi

  access_err="$(mktemp)"
  if patreage_client repo-access --repo "${PREVIEW_RELEASE_REPO}" >/dev/null 2>"${access_err}"; then
    info "Preview repo access granted"
  else
    error_line="$(sed -n '1p' "${access_err}" 2>/dev/null || true)"
    info "Preview repo access denied or unavailable (${error_line:-unknown error})"
  fi
  rm -f "${access_err}"
}

start_background() {
  "${INSTALL_DIR}/run-deskflow" "$@" </dev/null >/dev/null 2>&1 &
  info "Started deskflow-core in the background (PID $!)."
}

command="${1:-}"
if [ -z "${command}" ]; then
  show_help
  exit 0
fi
shift

case "${command}" in
  install|preview-login|preview-logout|preview-status|help|--help|-h) ;;
  *)
    if [ ! -f "${INSTALL_DIR}/.channel" ]; then
      if [ "${command}" = "remove" ]; then
        info "Deskflow isn't installed. To remove this entrypoint, run:"
        info "  rm ${0}"
        exit 0
      else
        die "Deskflow isn't installed. Run 'deskflow install' first."
      fi
    fi
    ;;
esac

case "${command}" in
  install)
    saved_channel=""
    if [ -f "${INSTALL_DIR}/.channel" ]; then
      saved_channel=$(cat "${INSTALL_DIR}/.channel")
    fi
    channel="${1:-${saved_channel:-latest}}"

    WORK_DIR=$(mktemp -d)
    trap 'rm -rf "${WORK_DIR}"' EXIT INT TERM

    if is_preview_channel "${channel}"; then
      ensure_preview_auth
    fi

    # ---------------------------------------------------------------------------
    # Resolve manifest URL via channel selector
    # ---------------------------------------------------------------------------

    tmp_selector="${WORK_DIR}/selector.json"
    fetch_channel_selector "${channel}" "${tmp_selector}"

    manifest_url=$(json_get manifest_url "${tmp_selector}")
    canonical_version=$(json_get canonical_version "${tmp_selector}")

    if [ -z "${manifest_url}" ]; then
      die "manifest_url not found in channel selector for '${channel}'"
    fi
    info "Resolved channel '${channel}' to ${canonical_version}"

    # ---------------------------------------------------------------------------
    # Fetch release manifest
    # ---------------------------------------------------------------------------

    info "Fetching release manifest: ${manifest_url}"

    tmp_manifest="${WORK_DIR}/manifest.json"
    release_tag=$(release_tag_from_manifest_url "${manifest_url}")
    release_repo=$(release_repo_from_manifest_url "${manifest_url}")
    if is_preview_release_asset "${release_repo}" "${release_tag}"; then
      download_preview_release_asset "${release_tag:-${canonical_version}}" "release-manifest.json" "${tmp_manifest}" \
        || die "Failed to fetch release manifest for '${release_tag:-${canonical_version}}'"
    else
      download "${manifest_url}" "${tmp_manifest}" \
        || die "Failed to fetch release manifest from ${manifest_url}"
    fi

    canonical_version=$(json_get canonical_version "${tmp_manifest}")
    app_archive=$(json_section_get app archive "${tmp_manifest}")
    app_sha256=$(json_section_get app sha256 "${tmp_manifest}")

    [ -n "${canonical_version}" ] || die "canonical_version not found in manifest"
    [ -n "${app_archive}" ]       || die "App archive name not found in manifest"

    # Derive the release download base URL from the manifest URL
    release_base=$(printf '%s' "${manifest_url}" | sed 's|/[^/]*$||')

    # ---------------------------------------------------------------------------
    # Download + verify app archive
    # ---------------------------------------------------------------------------

    info "Downloading app: ${app_archive}"
    tmp_app="${WORK_DIR}/app.tar.gz"
    if is_preview_release_asset "${release_repo}" "${release_tag}"; then
      download_preview_release_asset "${release_tag:-${canonical_version}}" "${app_archive}" "${tmp_app}"
    else
      download "${release_base}/${app_archive}" "${tmp_app}"
    fi

    if [ -n "${app_sha256}" ]; then
      actual=$(sha256_file "${tmp_app}")
      [ "${actual}" = "${app_sha256}" ] \
        || die "App archive SHA256 mismatch: expected ${app_sha256}, got ${actual}"
    fi

    # ---------------------------------------------------------------------------
    # Extract app archive directly to INSTALL_DIR
    # ---------------------------------------------------------------------------

    # Stop any running deskflow-core before replacing binaries
    if killall deskflow-core 2>/dev/null; then
      info "Stopped running Deskflow process."
    fi

    mkdir -p "${INSTALL_DIR}"
    info "Extracting app archive to ${INSTALL_DIR}"
    tar -xzf "${tmp_app}" -C "${INSTALL_DIR}" --strip-components=1

    # ---------------------------------------------------------------------------
    # Delegate to the now-installed installer for runtime/xkb
    # ---------------------------------------------------------------------------

    bash "${INSTALL_DIR}/install-deskflow" "${manifest_url}"

    printf '%s' "${channel}"           > "${INSTALL_DIR}/.channel"
    printf '%s' "${canonical_version}" > "${INSTALL_DIR}/.installed-version"
    ;;

  remove)
    if killall deskflow-core 2>/dev/null; then
      info "Stopped running deskflow-core process."
    fi
    for hook in /etc/network/if-up.d/deskflow /etc/network/if-down.d/deskflow; do
      if [ -f "${hook}" ]; then
        rm -f "${hook}"
        info "Removed ${hook}"
      fi
    done
    if [ -d "${INSTALL_DIR}" ]; then
      rm -rf "${INSTALL_DIR}"
      info "Removed ${INSTALL_DIR}"
    fi
    info "Deskflow app, runtime bundles, and hooks are removed."
    info "To further remove this entrypoint, run:"
    info "  rm ${0}"
    ;;

  start)
    start_background "$@"
    ;;

  run)
    DESKFLOW_SILENT=0 exec "${INSTALL_DIR}/run-deskflow" "$@"
    ;;

  stop)
    if killall deskflow-core 2>/dev/null; then
      info "Stopped running deskflow-core process."
    else
      info "deskflow-core is not running."
    fi
    ;;

  enable-autostart)
    sh "${INSTALL_DIR}/manage-deskflow" enable-autostart
    ;;

  disable-autostart)
    sh "${INSTALL_DIR}/manage-deskflow" disable-autostart
    ;;

  update)
    channel=$(cat "${INSTALL_DIR}/.channel")
    info "Checking channel '${channel}' for updates..."

    WORK_DIR=$(mktemp -d)
    trap 'rm -rf "${WORK_DIR}"' EXIT INT TERM

    if is_preview_channel "${channel}"; then
      ensure_preview_auth
    fi

    tmp_selector="${WORK_DIR}/selector.json"
    fetch_channel_selector "${channel}" "${tmp_selector}"

    available_version=$(json_get canonical_version "${tmp_selector}")
    if [ -z "${available_version}" ]; then
      die "canonical_version not found in channel selector for '${channel}'"
    fi

    installed_version=""
    if [ -f "${INSTALL_DIR}/.installed-version" ]; then
      installed_version=$(cat "${INSTALL_DIR}/.installed-version")
    fi

    if [ -n "${installed_version}" ] && [ "${installed_version}" = "${available_version}" ]; then
      info "Already up to date (${installed_version})."
    else
      if [ -n "${installed_version}" ]; then
        info "Update available: ${installed_version} to ${available_version}"
      else
        info "No version record found; reinstalling ${available_version}..."
      fi
      exec "${SCRIPT_DIR}/deskflow" install "${channel}"
    fi
    ;;

  preview-login)
    ensure_patreage_module
    patreage_require_runtime
    patreage_client login
    verify_preview_repo_access
    info "Preview access verified."
    ;;

  preview-logout)
    ensure_patreage_module
    patreage_client logout
    ;;

  preview-status)
    show_preview_status
    ;;

  configure)
    info "GUI configuration not yet available. A text editor can be opened using:"
    info "${SCRIPT_DIR}/deskflow configure-from-cli"
    ;;

  configure-from-cli)
    editor=$(find_text_editor) || die "No text editor found; install nano or vi, or set \$EDITOR"
    exec "${editor}" "${INSTALL_DIR}/deskflow.conf"
    ;;

  fingerprint-trust)
    mode="${1:-}"
    [ -n "${mode}" ] || die "Usage: deskflow fingerprint-trust strict|tofu|promiscuous"
    exec sh "${INSTALL_DIR}/manage-deskflow" set-fingerprint-trust "${mode}"
    ;;

  show-fingerprint-trust)
    exec sh "${INSTALL_DIR}/manage-deskflow" show-fingerprint-trust
    ;;

  status)
    [ -f "${INSTALL_DIR}/.channel" ] \
      && channel=$(cat "${INSTALL_DIR}/.channel")
    [ -f "${INSTALL_DIR}/.installed-version" ] \
      && installed_version=$(cat "${INSTALL_DIR}/.installed-version")
    [ -f "${INSTALL_DIR}/.runtime-fingerprint" ] \
      && runtime_fp=$(cat "${INSTALL_DIR}/.runtime-fingerprint")
    [ -f "${INSTALL_DIR}/.xkb-fingerprint" ] \
      && xkb_fp=$(cat "${INSTALL_DIR}/.xkb-fingerprint")

    if killall -0 deskflow-core 2>/dev/null; then
      service_state="running"
    else
      service_state="stopped"
    fi

    info "Channel:  ${channel:-unknown}"
    info "Version:  ${installed_version:-unknown}"
    info "Service:  ${service_state}"
    info "Runtime:  ${runtime_fp:-unknown}"
    info "XKB:      ${xkb_fp:-unknown}"
    ;;

  help|--help|-h)
    show_help
    ;;

  *)
    if [ -f "${INSTALL_DIR}/.channel" ]; then
      die "Unknown command '${command}'. Run 'deskflow help' for usage"
    else
      die "Unknown command '${command}'. Deskflow isn't installed; run 'deskflow install' first."
    fi
    ;;
esac
