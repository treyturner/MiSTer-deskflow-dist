patreage__state_dir() {
	local base_dir
	base_dir="${PATREAGE__STATE_DIR:-${XDG_STATE_HOME:-}}"
	if [[ -z "${base_dir}" ]]; then
		if [[ -d "/media/fat/Scripts" ]]; then
			base_dir="/media/fat/Scripts/.config"
		else
			base_dir="${HOME}/.local/state"
		fi
	fi
	printf '%s\n' "${base_dir}/patreage"
}

patreage__state_file() {
	printf '%s/session.json\n' "$(patreage__state_dir)"
}

patreage__state_file_exists() {
	[[ -f "$(patreage__state_file)" ]]
}

patreage__path_mode() {
	local path="$1"
	stat -c '%a' "${path}"
}

patreage__mode_is_private() {
	local mode="$1"
	(((8#${mode} & 077) == 0))
}

patreage__repair_private_permissions() {
	local path="$1"
	local desired_mode="$2"
	local mode

	chmod "${desired_mode}" "${path}" >/dev/null 2>&1 || return 1
	mode="$(patreage__path_mode "${path}")" || return 1
	if patreage__mode_is_private "${mode}"; then
		return 0
	fi

	return 2
}

patreage__repair_or_accept_private_permissions() {
	local repair_status=0

	patreage__repair_private_permissions "$@" || repair_status=$?
	[[ "${repair_status}" -eq 0 || "${repair_status}" -eq 2 ]]
}

patreage__ensure_private_permissions() {
	local path="$1"
	local desired_mode="$2"
	local mode

	mode="$(patreage__path_mode "${path}")" || return 1
	if patreage__mode_is_private "${mode}"; then
		return 0
	fi

	patreage__repair_or_accept_private_permissions "${path}" "${desired_mode}"
}

patreage__remove_new_empty_state_dir() {
	local state_dir="$1"
	local state_dir_existed="$2"

	if [[ "${state_dir_existed}" == "0" ]]; then
		rmdir "${state_dir}" >/dev/null 2>&1 || true
	fi
}

patreage__validate_state_path_permissions() {
	local state_dir
	local state_file

	state_dir="$(patreage__state_dir)"
	state_file="$(patreage__state_file)"

	if [[ -d "${state_dir}" ]]; then
		if ! patreage__ensure_private_permissions "${state_dir}" 700; then
			patreage__warn "state directory permissions are too open: ${state_dir}"
			return 1
		fi
	fi

	if [[ -f "${state_file}" ]]; then
		if ! patreage__ensure_private_permissions "${state_file}" 600; then
			patreage__warn "state file permissions are too open: ${state_file}"
			return 1
		fi
	fi

	return 0
}

patreage__ensure_state_dir() {
	local state_dir
	local state_dir_existed=0

	state_dir="$(patreage__state_dir)"
	if [[ -d "${state_dir}" ]]; then
		state_dir_existed=1
	fi

	if ! mkdir -p "${state_dir}"; then
		return 1
	fi
	if ! patreage__repair_or_accept_private_permissions "${state_dir}" 700; then
		patreage__remove_new_empty_state_dir "${state_dir}" "${state_dir_existed}"
		return 1
	fi
}

patreage__write_state_json() {
	local payload="$1"
	local old_umask
	local state_dir
	local state_dir_existed=0
	local state_file
	local temp_file

	if ! patreage__validate_state_path_permissions; then
		return 1
	fi

	state_dir="$(patreage__state_dir)"
	if [[ -d "${state_dir}" ]]; then
		state_dir_existed=1
	fi

	if ! patreage__ensure_state_dir; then
		return 1
	fi
	state_file="$(patreage__state_file)"
	old_umask="$(umask)"
	umask 077
	temp_file="$(mktemp "${state_dir}/session.json.tmp.XXXXXX")" || {
		umask "${old_umask}"
		patreage__remove_new_empty_state_dir "${state_dir}" "${state_dir_existed}"
		return 1
	}

	if ! patreage__repair_or_accept_private_permissions "${temp_file}" 600; then
		rm -f "${temp_file}"
		umask "${old_umask}"
		patreage__remove_new_empty_state_dir "${state_dir}" "${state_dir_existed}"
		return 1
	fi
	if ! printf '%s\n' "${payload}" >"${temp_file}"; then
		rm -f "${temp_file}"
		umask "${old_umask}"
		patreage__remove_new_empty_state_dir "${state_dir}" "${state_dir_existed}"
		return 1
	fi
	if ! patreage__repair_or_accept_private_permissions "${temp_file}" 600; then
		rm -f "${temp_file}"
		umask "${old_umask}"
		patreage__remove_new_empty_state_dir "${state_dir}" "${state_dir_existed}"
		return 1
	fi
	if ! mv -f "${temp_file}" "${state_file}"; then
		rm -f "${temp_file}"
		umask "${old_umask}"
		patreage__remove_new_empty_state_dir "${state_dir}" "${state_dir_existed}"
		return 1
	fi
	if ! patreage__repair_or_accept_private_permissions "${state_dir}" 700 ||
		! patreage__repair_or_accept_private_permissions "${state_file}" 600; then
		rm -f "${state_file}"
		umask "${old_umask}"
		patreage__remove_new_empty_state_dir "${state_dir}" "${state_dir_existed}"
		return 1
	fi
	umask "${old_umask}"
}

patreage__read_state_json() {
	local state_file

	state_file="$(patreage__state_file)"
	if [[ ! -f "${state_file}" ]]; then
		return 1
	fi

	if ! patreage__validate_state_path_permissions; then
		return 2
	fi

	cat "${state_file}"
}

patreage__state_json_is_valid() {
	local state_json="$1"

	printf '%s\n' "${state_json}" | jq -e '
    (.api_base_url | type == "string")
    and (.broker_session_id | type == "string")
    and (.access_token | type == "string")
    and (.access_token_expires_at | type == "string")
    and (.refresh_token | type == "string")
    and (.refresh_token_expires_at | type == "string")
    and (.token_type | type == "string")
  ' >/dev/null 2>&1
}

patreage__state_json_field() {
	local state_json="$1"
	local query="$2"

	printf '%s\n' "${state_json}" | jq -r "${query}"
}

patreage__state_timestamp_expired() {
	local state_json="$1"
	local field_name="$2"

	printf '%s\n' "${state_json}" | jq -e --arg field_name "${field_name}" '
    def parse_time:
      if endswith("+00:00") then .[0:(length - 6)] + "Z" else . end
      | if endswith("Z") and (index(".") != null) then .[0:index(".")] + "Z" else . end
      | fromdateiso8601;
    now >= (.[$field_name] | parse_time)
  ' >/dev/null 2>&1
}

patreage__build_refreshed_state_json() {
	local state_json="$1"
	local refresh_response_json="$2"
	local access_token
	local access_token_expires_at

	access_token="$(printf '%s\n' "${refresh_response_json}" | jq -r '.access_token')"
	access_token_expires_at="$(printf '%s\n' "${refresh_response_json}" | jq -r '.access_token_expires_at')"

	printf '%s\n' "${state_json}" | jq \
		--arg access_token "${access_token}" \
		--arg access_token_expires_at "${access_token_expires_at}" \
		'
      .access_token = $access_token
      | .access_token_expires_at = $access_token_expires_at
      | .written_at = (now | todateiso8601)
    '
}

patreage__remove_state_file() {
	local state_file

	state_file="$(patreage__state_file)"
	if [[ -f "${state_file}" ]]; then
		rm -f "${state_file}"
	fi
}
# End generated content from clients/shell/lib/session.sh

# Begin generated content from clients/shell/lib/repo_access.sh
patreage__clear_session_resolution() {
	PATREAGE__SESSION_STATE_JSON=""
	PATREAGE__SESSION_API_BASE_URL=""
	PATREAGE__SESSION_ACCESS_TOKEN=""
	PATREAGE__SESSION_ERROR_CODE=""
	PATREAGE__SESSION_ERROR_DETAIL=""
	PATREAGE__REFRESHED_STATE_JSON=""
}

patreage__clear_repo_access_check_resolution() {
	PATREAGE__REPO_ACCESS_CHECK_RESPONSE_JSON="null"
	PATREAGE__REPO_ACCESS_CHECK_HTTP_STATUS=""
	PATREAGE__REPO_ACCESS_CHECK_ERROR_CODE=""
	PATREAGE__REPO_ACCESS_CHECK_DETAIL=""
	PATREAGE__REPO_ACCESS_CHECK_REFRESH_OUTCOME="not_attempted"
}

patreage__repo_access_check_http_status_json() {
	local http_status="$1"

	if [[ "${http_status}" =~ ^[0-9]+$ && "${http_status}" != "000" ]]; then
		printf '%s\n' "${http_status}"
		return 0
	fi

	printf 'null\n'
}

patreage__repo_access_check_error_json() {
	local error_code="$1"
	local detail="$2"

	jq -n \
		--arg error_code "${error_code}" \
		--arg detail "${detail}" \
		'{
      error: (if $error_code == "" then null else $error_code end),
      detail: (if $detail == "" then null else $detail end)
    }'
}

patreage__repo_access_check_request() {
	local repo_selector="${1:-}"
	local payload='{}'
	local http_status_json

	patreage__clear_repo_access_check_resolution
	payload="$(patreage__repo_access_payload_with_repo "${payload}" "${repo_selector}")"

	if ! patreage__resolve_repo_session 2>/dev/null; then
		PATREAGE__REPO_ACCESS_CHECK_ERROR_CODE="${PATREAGE__SESSION_ERROR_CODE}"
		PATREAGE__REPO_ACCESS_CHECK_DETAIL="${PATREAGE__SESSION_ERROR_DETAIL}"
		PATREAGE__REPO_ACCESS_CHECK_RESPONSE_JSON="$(
			patreage__repo_access_check_error_json \
				"${PATREAGE__REPO_ACCESS_CHECK_ERROR_CODE}" \
				"${PATREAGE__REPO_ACCESS_CHECK_DETAIL}"
		)"
		return 1
	fi

	if [[ -n "${PATREAGE__REFRESHED_STATE_JSON}" ]]; then
		PATREAGE__REPO_ACCESS_CHECK_REFRESH_OUTCOME="refreshed"
	else
		PATREAGE__REPO_ACCESS_CHECK_REFRESH_OUTCOME="not_needed"
	fi

	if ! patreage__api_request_json \
		"POST" \
		"/v1/repo-access/check" \
		"${payload}" \
		"${PATREAGE__SESSION_ACCESS_TOKEN}" \
		"${PATREAGE__SESSION_API_BASE_URL}" 2>/dev/null; then
		PATREAGE__REPO_ACCESS_CHECK_ERROR_CODE="request_failed"
		PATREAGE__REPO_ACCESS_CHECK_DETAIL="failed to contact API at ${PATREAGE__SESSION_API_BASE_URL}"
		PATREAGE__REPO_ACCESS_CHECK_HTTP_STATUS=""
		PATREAGE__REPO_ACCESS_CHECK_RESPONSE_JSON="$(
			patreage__repo_access_check_error_json \
				"${PATREAGE__REPO_ACCESS_CHECK_ERROR_CODE}" \
				"${PATREAGE__REPO_ACCESS_CHECK_DETAIL}"
		)"
		return 1
	fi

	http_status_json="$(patreage__repo_access_check_http_status_json "${PATREAGE__HTTP_RESPONSE_STATUS}")"
	PATREAGE__REPO_ACCESS_CHECK_HTTP_STATUS="$(
		jq -nr --argjson http_status "${http_status_json}" '$http_status // empty'
	)"
	PATREAGE__REPO_ACCESS_CHECK_RESPONSE_JSON="${PATREAGE__HTTP_RESPONSE_BODY}"
	if [[ -z "${PATREAGE__REPO_ACCESS_CHECK_RESPONSE_JSON}" ]]; then
		PATREAGE__REPO_ACCESS_CHECK_RESPONSE_JSON="null"
	fi

	if [[ "${PATREAGE__HTTP_RESPONSE_STATUS}" != "200" ]]; then
		PATREAGE__REPO_ACCESS_CHECK_ERROR_CODE="$(
			printf '%s\n' "${PATREAGE__REPO_ACCESS_CHECK_RESPONSE_JSON}" | jq -r '.error // empty'
		)"
		PATREAGE__REPO_ACCESS_CHECK_DETAIL="$(patreage__response_detail)"
		return 1
	fi

	return 0
}

patreage__refresh_broker_access_token() {
	local state_json="$1"
	local refresh_token
	local api_base_url
	local refresh_payload
	local updated_state_json

	PATREAGE__REFRESHED_STATE_JSON=""
	refresh_token="$(patreage__state_json_field "${state_json}" '.refresh_token')"
	api_base_url="$(patreage__state_json_field "${state_json}" '.api_base_url')"
	refresh_payload="$(jq -n --arg refresh_token "${refresh_token}" '{refresh_token: $refresh_token}')"

	if ! patreage__api_request_json "POST" "/v1/broker-sessions/refresh" "${refresh_payload}" "" "${api_base_url}"; then
		PATREAGE__SESSION_ERROR_CODE="$(patreage__machine_code credential_helper_codes refresh_failed)"
		PATREAGE__SESSION_ERROR_DETAIL="failed to reach the API to refresh the broker access token"
		return 1
	fi

	if [[ "${PATREAGE__HTTP_RESPONSE_STATUS}" != "200" ]]; then
		PATREAGE__SESSION_ERROR_CODE="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.error // empty')"
		if [[ -z "${PATREAGE__SESSION_ERROR_CODE}" ]]; then
			PATREAGE__SESSION_ERROR_CODE="$(patreage__machine_code credential_helper_codes refresh_failed)"
		fi
		PATREAGE__SESSION_ERROR_DETAIL="$(patreage__response_detail)"
		return 1
	fi

	updated_state_json="$(patreage__build_refreshed_state_json "${state_json}" "${PATREAGE__HTTP_RESPONSE_BODY}")"
	if ! patreage__write_state_json "${updated_state_json}"; then
		PATREAGE__SESSION_ERROR_CODE="$(patreage__machine_code credential_helper_codes refresh_failed)"
		PATREAGE__SESSION_ERROR_DETAIL="failed to persist refreshed local session state"
		return 1
	fi

	PATREAGE__REFRESHED_STATE_JSON="${updated_state_json}"
	return 0
}

patreage__resolve_repo_session() {
	local state_json
	local read_exit=0

	patreage__clear_session_resolution

	if state_json="$(patreage__read_state_json)"; then
		:
	else
		read_exit=$?
		if [[ "${read_exit}" -eq 2 ]]; then
			PATREAGE__SESSION_ERROR_CODE="invalid_state_permissions"
			PATREAGE__SESSION_ERROR_DETAIL="local session state permissions are invalid"
			return 1
		fi

		PATREAGE__SESSION_ERROR_CODE="$(patreage__machine_code credential_helper_codes not_logged_in)"
		PATREAGE__SESSION_ERROR_DETAIL="patreage login is required"
		return 1
	fi

	if ! printf '%s\n' "${state_json}" | jq empty >/dev/null 2>&1; then
		PATREAGE__SESSION_ERROR_CODE="invalid_state_json"
		PATREAGE__SESSION_ERROR_DETAIL="local session state is invalid"
		return 1
	fi

	if ! patreage__state_json_is_valid "${state_json}"; then
		PATREAGE__SESSION_ERROR_CODE="invalid_state_json"
		PATREAGE__SESSION_ERROR_DETAIL="local session state is invalid"
		return 1
	fi

	if patreage__state_timestamp_expired "${state_json}" "refresh_token_expires_at"; then
		PATREAGE__SESSION_ERROR_CODE="$(patreage__machine_code broker_refresh_error_codes expired_refresh_token)"
		PATREAGE__SESSION_ERROR_DETAIL="local broker session has expired; run patreage login again"
		return 1
	fi

	if patreage__state_timestamp_expired "${state_json}" "access_token_expires_at"; then
		if ! patreage__refresh_broker_access_token "${state_json}"; then
			return 1
		fi
		state_json="${PATREAGE__REFRESHED_STATE_JSON}"
	fi

	PATREAGE__SESSION_STATE_JSON="${state_json}"
	PATREAGE__SESSION_API_BASE_URL="$(patreage__state_json_field "${state_json}" '.api_base_url')"
	PATREAGE__SESSION_ACCESS_TOKEN="$(patreage__state_json_field "${state_json}" '.access_token')"
	return 0
}

patreage__repo_access_output_json() {
	local response_json="$1"
	local credential_context_url
	local helper_key
	local use_http_path_key
	local unset_helper_command
	local add_helper_command
	local use_http_path_command

	credential_context_url="$(printf '%s\n' "${response_json}" | jq -r '.credential_context_url')"
	if ! patreage__validate_github_clone_url "${credential_context_url}"; then
		patreage__die "unsafe credential context URL was returned by the API"
	fi

	helper_key="credential.${credential_context_url}.helper"
	use_http_path_key="credential.${credential_context_url}.useHttpPath"
	unset_helper_command="$(patreage__shell_join git config --global --unset-all "${helper_key}") || true"
	add_helper_command="$(patreage__shell_join git config --global --add "${helper_key}" "!patreage credential-helper")"
	use_http_path_command="$(patreage__shell_join git config --global "${use_http_path_key}" true)"

	printf '%s\n' "${response_json}" | jq \
		--arg unset_helper_command "${unset_helper_command}" \
		--arg add_helper_command "${add_helper_command}" \
		--arg use_http_path_command "${use_http_path_command}" \
		'
      . + {
        git_config_commands: [
          $unset_helper_command,
          $add_helper_command,
          $use_http_path_command
        ]
      }
    '
}

patreage__credential_helper_mismatch_code() {
	local protocol="$1"
	local host="$2"

	if [[ "${protocol}" != "${PATREAGE__REPO_ACCESS_PROTOCOL}" ]]; then
		patreage__machine_code credential_helper_codes protocol_mismatch
		return 0
	fi
	if [[ "${host}" != "${PATREAGE__REPO_ACCESS_HOST}" ]]; then
		patreage__machine_code credential_helper_codes host_mismatch
		return 0
	fi

	printf '\n'
}

patreage__credential_helper_print_error() {
	local code="$1"
	local detail="$2"

	if [[ -z "${code}" ]]; then
		code="$(patreage__machine_code credential_helper_codes request_failed)"
	fi
	if [[ -z "${detail}" ]]; then
		detail="request failed"
	fi

	printf 'error: %s [%s]\n' "${detail}" "${code}" >&2
}

patreage__repo_access_json_request_or_die() {
	local endpoint_path="$1"
	local payload="$2"
	local error_code=""

	patreage__require_command jq
	patreage__require_command curl

	if ! patreage__resolve_repo_session; then
		patreage__die "${PATREAGE__SESSION_ERROR_DETAIL}"
	fi

	if ! patreage__api_request_json \
		"POST" \
		"${endpoint_path}" \
		"${payload}" \
		"${PATREAGE__SESSION_ACCESS_TOKEN}" \
		"${PATREAGE__SESSION_API_BASE_URL}"; then
		patreage__die "failed to contact API at ${PATREAGE__SESSION_API_BASE_URL}"
	fi

	if [[ "${PATREAGE__HTTP_RESPONSE_STATUS}" != "200" ]]; then
		error_code="$(printf '%s\n' "${PATREAGE__HTTP_RESPONSE_BODY}" | jq -r '.error // empty')"
		if [[ -n "${error_code}" ]]; then
			patreage__die "$(patreage__response_detail) [${error_code}]"
		fi
		patreage__die "$(patreage__response_detail)"
	fi
}

patreage__repo_access_normalize_contents_path() {
	local raw_path="$1"

	case "${raw_path}" in
	"" | "." | "/")
		printf '\n'
		;;
	*)
		printf '%s\n' "${raw_path#"/"}"
		;;
	esac
}

patreage__repo_access_payload_with_repo() {
	local payload="$1"
	local repo_selector="${2:-}"

	if [[ -z "${repo_selector}" ]]; then
		printf '%s\n' "${payload}"
		return 0
	fi

	printf '%s\n' "${payload}" | jq \
		--arg repo "${repo_selector}" \
		'. + {repo: $repo}'
}

patreage__repo_access_download_archive() {
	local download_url="$1"
	local output_mode="$2"
	local output_path="${3:-}"
	local temp_file=""
	local output_dir=""

	if ! patreage__validate_github_https_url "${download_url}"; then
		patreage__die "unsafe archive download URL was returned by the API"
	fi

	if [[ "${output_mode}" == "stdout" ]]; then
		if [[ -t 1 ]]; then
			patreage__die "refusing to write archive bytes to an interactive terminal; use --output PATH or pipe --stdout"
		fi
		if ! curl -fsSL --proto '=https' --proto-redir '=https' "${download_url}"; then
			patreage__die "failed to download archive"
		fi
		return 0
	fi

	output_dir="$(dirname -- "${output_path}")"
	temp_file="$(mktemp "${output_dir}/patreage-archive.XXXXXX")" || {
		patreage__die "failed to create a temporary archive file in ${output_dir}"
	}

	if ! curl -fsSL --proto '=https' --proto-redir '=https' --output "${temp_file}" "${download_url}"; then
		rm -f "${temp_file}"
		patreage__die "failed to download archive"
	fi

	if ! mv -f "${temp_file}" "${output_path}"; then
		rm -f "${temp_file}"
		patreage__die "failed to move the archive into place at ${output_path}"
	fi
}

patreage__repo_access_release_failure_json() {
	local repo_selector="$1"
	local release_tag="$2"
	local asset_name="$3"
	local output_path="$4"
	local result_code="$5"
	local detail="$6"
	local http_status_json="$7"

	jq -n \
		--arg result_code "${result_code}" \
		--arg repo "${repo_selector}" \
		--arg tag "${release_tag}" \
		--arg asset "${asset_name}" \
		--arg output "${output_path}" \
		--arg detail "${detail}" \
		--argjson http_status "${http_status_json}" \
		'{
      ok: false,
      result_code: $result_code,
      repo: $repo,
      tag: $tag,
      asset: $asset,
      output: $output,
      detail: $detail,
      http_status: $http_status
    }'
}

patreage__repo_access_release_success_json() {
	local repo_selector="$1"
	local release_tag="$2"
	local asset_name="$3"
	local output_path="$4"
	local bytes_written="$5"
	local result_code

	result_code="$(patreage__machine_code repo_access_release_result_codes asset_downloaded)"
	jq -n \
		--arg result_code "${result_code}" \
		--arg repo "${repo_selector}" \
		--arg tag "${release_tag}" \
		--arg asset "${asset_name}" \
		--arg output "${output_path}" \
		--argjson bytes_written "${bytes_written}" \
		'{
      ok: true,
      result_code: $result_code,
      repo: $repo,
      tag: $tag,
      asset: $asset,
      output: $output,
      bytes_written: $bytes_written
    }'
}

patreage__repo_access_release_http_status_json() {
	local http_status="$1"

	if [[ "${http_status}" =~ ^[0-9]+$ && "${http_status}" != "000" ]]; then
		printf '%s\n' "${http_status}"
		return 0
	fi

	printf 'null\n'
}

patreage__repo_access_release_fail() {
	local json_output="$1"
	local repo_selector="$2"
	local release_tag="$3"
	local asset_name="$4"
	local output_path="$5"
	local result_code="$6"
	local detail="$7"
	local http_status="${8:-}"
	local http_status_json

	if [[ -z "${result_code}" ]]; then
		result_code="$(patreage__machine_code repo_access_release_error_codes download_failed)"
	fi
	if [[ -z "${detail}" ]]; then
		detail="release asset download failed"
	fi
	http_status_json="$(patreage__repo_access_release_http_status_json "${http_status}")"

	if [[ "${json_output}" == "1" ]]; then
		patreage__repo_access_release_failure_json \
			"${repo_selector}" \
			"${release_tag}" \
			"${asset_name}" \
			"${output_path}" \
			"${result_code}" \
			"${detail}" \
			"${http_status_json}"
	else
		printf 'error: %s [%s]\n' "${detail}" "${result_code}" >&2
	fi
	exit 1
}

patreage__repo_access_release_error_from_file() {
	local error_file="$1"
	local fallback_code

	fallback_code="$(patreage__machine_code repo_access_release_error_codes download_failed)"
	if jq -er '.error // empty' "${error_file}" >/dev/null 2>&1; then
		jq -r '.error' "${error_file}"
		return 0
	fi

	printf '%s\n' "${fallback_code}"
}

patreage__repo_access_release_detail_from_file() {
	local error_file="$1"

	if jq -er '.detail // empty' "${error_file}" >/dev/null 2>&1; then
		jq -r '.detail' "${error_file}"
		return 0
	fi

	printf 'release asset download failed\n'
}

patreage__repo_access_download_release_asset() {
	local payload="$1"
	local output_path="$2"
	local json_output="$3"
	local repo_selector="$4"
	local release_tag="$5"
	local asset_name="$6"
	local endpoint_path="/v1/repo-access/github-release/asset"
	local output_dir
	local temp_file=""
	local status_code=""
	local curl_exit=0
	local bytes_written
	local error_code
	local error_detail
	local url
	local -a curl_args

	patreage__require_command jq
	patreage__require_command curl

	output_dir="$(dirname -- "${output_path}")"
	temp_file="$(mktemp "${output_dir}/patreage-release-asset.XXXXXX")" || {
		patreage__repo_access_release_fail \
			"${json_output}" \
			"${repo_selector}" \
			"${release_tag}" \
			"${asset_name}" \
			"${output_path}" \
			"$(patreage__machine_code repo_access_release_error_codes download_failed)" \
			"failed to create a temporary release asset file in ${output_dir}" \
			""
	}

	if ! patreage__resolve_repo_session; then
		rm -f "${temp_file}"
		patreage__repo_access_release_fail \
			"${json_output}" \
			"${repo_selector}" \
			"${release_tag}" \
			"${asset_name}" \
			"${output_path}" \
			"${PATREAGE__SESSION_ERROR_CODE}" \
			"${PATREAGE__SESSION_ERROR_DETAIL}" \
			""
	fi

	url="${PATREAGE__SESSION_API_BASE_URL}${endpoint_path}"
	curl_args=(
		-sS
		-o "${temp_file}"
		-w '%{http_code}'
		-X POST
		-H 'Accept: application/octet-stream'
		-H 'Content-Type: application/json'
		-H "Authorization: Bearer ${PATREAGE__SESSION_ACCESS_TOKEN}"
		--data "${payload}"
		"${url}"
	)

	if status_code="$(curl "${curl_args[@]}")"; then
		curl_exit=0
	else
		curl_exit=$?
	fi

	if [[ "${curl_exit}" -ne 0 ]]; then
		rm -f "${temp_file}"
		patreage__repo_access_release_fail \
			"${json_output}" \
			"${repo_selector}" \
			"${release_tag}" \
			"${asset_name}" \
			"${output_path}" \
			"$(patreage__machine_code repo_access_release_error_codes download_failed)" \
			"failed to contact API at ${PATREAGE__SESSION_API_BASE_URL}" \
			""
	fi

	if [[ "${status_code}" != "200" ]]; then
		error_code="$(patreage__repo_access_release_error_from_file "${temp_file}")"
		error_detail="$(patreage__repo_access_release_detail_from_file "${temp_file}")"
		rm -f "${temp_file}"
		patreage__repo_access_release_fail \
			"${json_output}" \
			"${repo_selector}" \
			"${release_tag}" \
			"${asset_name}" \
			"${output_path}" \
			"${error_code}" \
			"${error_detail}" \
			"${status_code}"
	fi

	bytes_written="$(wc -c <"${temp_file}")"
	bytes_written="${bytes_written//[[:space:]]/}"
	if ! mv -f "${temp_file}" "${output_path}"; then
		rm -f "${temp_file}"
		patreage__repo_access_release_fail \
			"${json_output}" \
			"${repo_selector}" \
			"${release_tag}" \
			"${asset_name}" \
			"${output_path}" \
			"$(patreage__machine_code repo_access_release_error_codes download_failed)" \
			"failed to move the release asset into place at ${output_path}" \
			""
	fi

	if [[ "${json_output}" == "1" ]]; then
		patreage__repo_access_release_success_json \
			"${repo_selector}" \
			"${release_tag}" \
			"${asset_name}" \
			"${output_path}" \
			"${bytes_written}"
	fi
}
