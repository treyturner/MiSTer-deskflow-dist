}

patreage__doctor_session_json() {
	local status_json="$1"
	local filter

	filter='{status:(if (.reason // "") == "not_logged_in" then "unauthenticated" elif (.reason // "") == "invalid_state_permissions" then "invalid" elif (.reason // "") == "invalid_state_json" then "invalid" elif (.authenticated // false) != true then "expired" else "authenticated" end),authenticated:(.authenticated // false),reason:(if (.reason // null) != null then .reason elif (.refresh_token_expired // false) == true then "refresh_token_expired" else null end),api_base_url:(.api_base_url // null),broker_session_id:(.broker_session_id // null),access_token_expired:(.access_token_expired // null),refresh_token_expired:(.refresh_token_expired // null),remote_summary_status:(.remote_summary_status // null),remote_summary_error:(.remote_summary_error // null),remote_summary_fetched_at:(.remote_summary_fetched_at // null),raw:.}'
	printf '%s\n' "${status_json}" | jq "${filter}"
}

patreage__doctor_repo_result_json() {
	local selector_json="$1"
	local target="$2"
	local repo_status="$3"
	local http_status_json="$4"
	local error_code="$5"
	local detail="$6"
	local result_json="$7"
	local refresh_outcome="$8"
	local filter

	filter='{selector:$selector,target:$target,status:$status,http_status:$http_status,error_code:(if $error_code == "" then null else $error_code end),detail:(if $detail == "" then null else $detail end),broker_refresh:{outcome:$refresh_outcome},result:($result // {})}'
	jq -n \
		--argjson selector "${selector_json}" \
		--arg target "${target}" \
		--arg status "${repo_status}" \
		--argjson http_status "${http_status_json}" \
		--arg error_code "${error_code}" \
		--arg detail "${detail}" \
		--argjson result "${result_json}" \
		--arg refresh_outcome "${refresh_outcome}" \
